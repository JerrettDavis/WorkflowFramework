@using System.Text.RegularExpressions
@using WorkflowFramework.Dashboard.Web.Services
@inject IJSRuntime JS
@inject DashboardApiClient Api
@inject ToastService Toast
@inject KeyboardShortcutService Shortcuts
@implements IAsyncDisposable

<div class="flex flex-col h-full">
    <WorkflowToolbar WorkflowName="@_workflowName"
                     OnWorkflowNameChanged="name => { _workflowName = name; _dirty = true; }"
                     IsDirty="_dirty"
                     OnNew="HandleNew"
                     OnOpen="() => _showOpenDialog = true"
                     OnSave="HandleSave"
                     OnRun="HandleRun"
                     OnExportJson="HandleExportJson"
                     OnExportYaml="HandleExportYaml"
                     OnImportFile="HandleImport"
                     OnFitView="HandleFitView"
                     OnTemplates="() => _showTemplateBrowser = true"
                     OnValidate="HandleValidate"
                     ValidationErrorCount="ValidationErrorCount"
                     OnSettings="() => _showSettings = true"
                     OnShortcutsHelp="() => _showShortcutsHelp = true" />

    <div class="flex flex-1 overflow-hidden">
        <StepPalette />

        <div class="flex-1 relative" id="workflow-canvas"></div>

        <PropertiesPanel SelectedNodeId="@_selectedNodeId"
                         SelectedNodeType="@_selectedNodeType"
                         NodeConfig="_selectedNodeConfig"
                         OnConfigChanged="HandleConfigChanged"
                         Connections="_selectedNodeConnections"
                         OnConnectionClicked="HandleFocusNode" />
    </div>

    @* Tabbed bottom panels *@
    <div class="border-t border-gray-700 bg-gray-800" data-testid="bottom-tabs">
        <div class="flex items-center border-b border-gray-700">
            <button @onclick='() => _activeBottomTab = "output"'
                    class="px-4 py-1.5 text-xs @(_activeBottomTab == "output" ? "text-blue-400 border-b-2 border-blue-400 bg-gray-850" : "text-gray-400 hover:text-gray-200")"
                    data-testid="tab-output">
                Output
                @if (_activeRunId is not null)
                {
                    <span class="ml-1 text-yellow-400">●</span>
                }
            </button>
            <button @onclick='() => { _activeBottomTab = "steps"; RefreshStepList(); }'
                    class="px-4 py-1.5 text-xs @(_activeBottomTab == "steps" ? "text-blue-400 border-b-2 border-blue-400 bg-gray-850" : "text-gray-400 hover:text-gray-200")"
                    data-testid="tab-steps">
                Steps
            </button>
            <button @onclick='() => _activeBottomTab = "triggers"'
                    class="px-4 py-1.5 text-xs @(_activeBottomTab == "triggers" ? "text-blue-400 border-b-2 border-blue-400 bg-gray-850" : "text-gray-400 hover:text-gray-200")"
                    data-testid="tab-triggers">
                ⚡ Triggers
            </button>
            <button @onclick='() => _activeBottomTab = "validation"'
                    class="px-4 py-1.5 text-xs @(_activeBottomTab == "validation" ? "text-blue-400 border-b-2 border-blue-400 bg-gray-850" : "text-gray-400 hover:text-gray-200")"
                    data-testid="tab-validation">
                Validation
                @if (_validationErrors.Count > 0)
                {
                    <span class="ml-1 px-1.5 py-0.5 rounded-full text-[10px] bg-red-500/20 text-red-400">@ValidationErrorCount</span>
                }
            </button>
            <button @onclick='() => _activeBottomTab = "run"'
                    class="px-4 py-1.5 text-xs @(_activeBottomTab == "run" ? "text-blue-400 border-b-2 border-blue-400 bg-gray-850" : "text-gray-400 hover:text-gray-200")"
                    data-testid="tab-run-assistant">
                🎙 Run Assistant
                @if (_runAssistantTasks.Count > 0)
                {
                    <span class="ml-1 px-1.5 py-0.5 rounded-full text-[10px] bg-cyan-500/20 text-cyan-300">@RunAssistantPendingCount</span>
                }
            </button>
            <div class="flex-1"></div>
            <button @onclick="() => _bottomPanelCollapsed = !_bottomPanelCollapsed"
                    class="px-3 py-1.5 text-xs text-gray-500 hover:text-gray-300"
                    data-testid="toggle-bottom-panel">
                @(_bottomPanelCollapsed ? "▲" : "▼")
            </button>
        </div>

        @if (!_bottomPanelCollapsed)
        {
            <div class="@BottomPanelHeightClass">
                @if (_activeBottomTab == "output")
                {
                    <div class="h-full overflow-y-auto p-3 bg-gray-900 text-xs text-gray-200 space-y-3" data-testid="output-content">
                        <section class="run-hero">
                            <div class="run-hero-row">
                                <div>
                                    <div class="run-kicker">Live Execution Feed</div>
                                    <div class="run-hero-title">@_workflowName</div>
                                    <div class="text-gray-300">
                                        @if (_activeRunId is not null)
                                        {
                                            <span>Run <span class="font-mono text-cyan-200">@_activeRunId[..Math.Min(10, _activeRunId.Length)]</span> in progress</span>
                                        }
                                        else if (_latestRunSummary is not null)
                                        {
                                            <span>Latest run <span class="font-mono text-gray-200">@_latestRunSummary.RunId[..Math.Min(10, _latestRunSummary.RunId.Length)]</span></span>
                                        }
                                        else
                                        {
                                            <span>Run a workflow to populate execution telemetry.</span>
                                        }
                                    </div>
                                    <div class="text-[10px] mt-1 @(_runHubConnected ? "text-emerald-300" : "text-amber-300")">
                                        Feed: @(_runHubConnected ? "Realtime SignalR" : "Polling fallback")
                                    </div>
                                </div>
                                <div class="run-status-badge @GetRunStatusBadgeClass()">
                                    <span class="run-status-dot"></span>
                                    @_runStatus
                                </div>
                            </div>

                            <div class="run-progress-track">
                                <div class="run-progress-fill" style="width:@($"{RunProgressPercent:0.#}%")"></div>
                            </div>
                        </section>

                        <section class="grid grid-cols-2 md:grid-cols-5 gap-2">
                            <article class="run-metric-card">
                                <div class="run-metric-label">Elapsed</div>
                                <div class="run-metric-value">@RunElapsedLabel</div>
                            </article>
                            <article class="run-metric-card">
                                <div class="run-metric-label">Known Steps</div>
                                <div class="run-metric-value">@KnownStepCount</div>
                            </article>
                            <article class="run-metric-card">
                                <div class="run-metric-label">Completed</div>
                                <div class="run-metric-value text-green-300">@CompletedStepCount</div>
                            </article>
                            <article class="run-metric-card">
                                <div class="run-metric-label">Running</div>
                                <div class="run-metric-value text-yellow-300">@RunningStepCount</div>
                            </article>
                            <article class="run-metric-card">
                                <div class="run-metric-label">Failed</div>
                                <div class="run-metric-value text-red-300">@FailedStepCount</div>
                            </article>
                        </section>

                        @if (!string.IsNullOrWhiteSpace(_activeStepName))
                        {
                            <section class="run-spotlight">
                                <span class="run-spotlight-dot"></span>
                                <span>Now Executing: <span class="text-white font-semibold">@_activeStepName</span></span>
                            </section>
                        }

                        @if (!string.IsNullOrWhiteSpace(_runErrorMessage))
                        {
                            <section class="run-error-banner">
                                <div class="font-semibold">Run error detected</div>
                                <div class="text-red-200 mt-0.5">@_runErrorMessage</div>
                            </section>
                        }

                        @if (_runTimeline.Count > 0)
                        {
                            <section class="run-timeline">
                                @foreach (var evt in _runTimeline.Take(18))
                                {
                                    <article class="run-event-row @GetRunEventRowClass(evt.Kind)">
                                        <div class="run-event-time">@evt.Timestamp.ToLocalTime().ToString("HH:mm:ss")</div>
                                        <div class="run-event-body">
                                            <div class="run-event-title">@evt.Title</div>
                                            @if (!string.IsNullOrWhiteSpace(evt.Detail))
                                            {
                                                <div class="run-event-detail">@evt.Detail</div>
                                            }
                                        </div>
                                    </article>
                                }
                            </section>
                        }
                        else
                        {
                            <p class="text-gray-500">Timeline updates appear here as steps execute.</p>
                        }

                        <details class="run-raw-log" open="@(_logEntries.Count > 0)">
                            <summary class="cursor-pointer select-none text-gray-300 hover:text-white">Raw run log (@_logEntries.Count)</summary>
                            <div class="mt-2 font-mono text-[11px] leading-5 max-h-56 overflow-y-auto pr-1">
                                @if (_logEntries.Count == 0)
                                {
                                    <p class="text-gray-500">No output yet. Run a workflow to see results.</p>
                                }
                                else
                                {
                                    @foreach (var entry in _logEntries.TakeLast(200))
                                    {
                                        <div class="py-0.5 @GetLogClass(entry)">@entry</div>
                                    }
                                }
                            </div>
                        </details>
                    </div>
                }
                else if (_activeBottomTab == "steps")
                {
                    <div class="h-full flex flex-col bg-gray-900">
                        <div class="px-3 py-2 border-b border-gray-700/80">
                            <div class="flex items-center justify-between mb-1">
                                <div class="text-[10px] uppercase tracking-wide text-cyan-300">Step Tracker</div>
                                <div class="run-status-badge @GetRunStatusBadgeClass()">
                                    <span class="run-status-dot"></span>
                                    @_runStatus
                                </div>
                            </div>
                            <div class="run-progress-track">
                                <div class="run-progress-fill" style="width:@($"{RunProgressPercent:0.#}%")"></div>
                            </div>
                            <div class="mt-1 text-[10px] text-gray-400">
                                @CompletedStepCount complete · @RunningStepCount active · @FailedStepCount failed
                                @if (!string.IsNullOrWhiteSpace(_activeStepName))
                                {
                                    <span class="ml-2 text-yellow-300">Now: @_activeStepName</span>
                                }
                            </div>
                        </div>
                        <div class="flex-1 min-h-0">
                            <StepListPanel @ref="_stepListPanel"
                                           SelectedNodeId="@_selectedNodeId"
                                           OnNodeClicked="HandleFocusNode" />
                        </div>
                    </div>
                }
                else if (_activeBottomTab == "triggers")
                {
                    <TriggerPanel WorkflowId="@_currentWorkflowId" />
                }
                else if (_activeBottomTab == "validation")
                {
                    <div class="h-full overflow-y-auto bg-gray-900" data-testid="validation-content">
                        @if (_validationErrors.Count == 0)
                        {
                            <div class="p-3 text-gray-600 text-xs">No validation errors. Click Validate to check.</div>
                        }
                        else
                        {
                            @foreach (var error in _validationErrors)
                            {
                                <button @onclick="() => HandleValidationErrorClicked(error.StepName)"
                                        class="w-full flex items-center gap-2 px-3 py-1 text-xs hover:bg-gray-700 text-left">
                                    <span class="@GetSeverityClass(error.Severity)">@GetSeverityIcon(error.Severity)</span>
                                    @if (error.StepName is not null)
                                    {
                                        <span class="text-blue-400 font-mono">@error.StepName</span>
                                    }
                                    <span class="text-gray-300">@error.Message</span>
                                </button>
                            }
                        }
                    </div>
                }
                else if (_activeBottomTab == "run")
                {
                    <div class="h-full overflow-y-auto p-3 bg-gray-900 text-xs text-gray-200" data-testid="run-assistant-content">
                        @if (!_runAssistantActive || _runAssistantTasks.Count == 0 || CurrentRunTask is null)
                        {
                            <div class="h-full grid place-items-center text-gray-500">
                                No interactive inputs needed. Click Run to execute immediately.
                            </div>
                        }
                        else
                        {
                            var task = CurrentRunTask;
                            <div class="flex items-center justify-between mb-2">
                                <div>
                                    <div class="text-[10px] uppercase tracking-wide text-cyan-300">Interactive Run</div>
                                    <div class="text-sm font-semibold text-gray-100">@task.Title</div>
                                    <div class="text-gray-400">@task.Instructions</div>
                                </div>
                                <button @onclick="CancelRunAssistant"
                                        class="px-2 py-1 rounded border border-gray-600 text-gray-300 hover:text-white hover:border-gray-500">
                                    Cancel
                                </button>
                            </div>

                            <div class="flex flex-wrap gap-1.5 mb-3">
                                @for (var i = 0; i < _runAssistantTasks.Count; i++)
                                {
                                    var idx = i;
                                    var stepTask = _runAssistantTasks[idx];
                                    var stepClass = idx == _runAssistantIndex
                                        ? "bg-cyan-500/20 text-cyan-200 border-cyan-400/40"
                                        : stepTask.Completed
                                            ? "bg-green-500/15 text-green-200 border-green-500/30"
                                            : "bg-gray-800 text-gray-400 border-gray-700";
                                    <button @onclick="() => JumpToRunTask(idx)"
                                            class="px-2 py-1 rounded border @stepClass">
                                        @(idx + 1). @stepTask.StepName
                                    </button>
                                }
                            </div>

                            @if (task.Kind == RunAssistantTaskKind.Record)
                            {
                                <div class="space-y-2">
                                    <div class="flex flex-wrap gap-2 items-center">
                                        <select @bind="_runSelectedDeviceId"
                                                class="px-2 py-1 bg-gray-800 border border-gray-700 rounded text-gray-200"
                                                disabled="@(!_runRecorderSupported || _runRecording)">
                                            @if (_runAudioDevices.Count == 0)
                                            {
                                                <option value="">Default microphone</option>
                                            }
                                            else
                                            {
                                                @foreach (var device in _runAudioDevices)
                                                {
                                                    <option value="@device.DeviceId">@device.Label</option>
                                                }
                                            }
                                        </select>

                                        <button @onclick="ToggleRunRecordingAsync"
                                                disabled="@(!_runRecorderSupported || _runBusy)"
                                                class="px-3 py-1 rounded @( _runRecording ? "bg-red-600 hover:bg-red-500 text-white" : "bg-cyan-600 hover:bg-cyan-500 text-white" ) disabled:opacity-50">
                                            @(_runRecording ? "Stop Recording" : "Start Recording")
                                        </button>

                                        <label class="px-3 py-1 rounded border border-gray-600 text-gray-300 hover:text-white cursor-pointer">
                                            Upload Audio
                                            <InputFile OnChange="HandleRunAudioUploadAsync"
                                                       accept="audio/*,.wav,.mp3,.m4a,.ogg,.webm,.flac"
                                                       disabled="@(_runRecording || _runBusy)" />
                                        </label>
                                    </div>

                                    @if (_runRecording || !string.IsNullOrWhiteSpace(_runLiveInterimTranscript))
                                    {
                                        <div class="p-2 bg-cyan-900/20 border border-cyan-800/50 rounded">
                                            <div class="text-cyan-200">Live transcript</div>
                                            <p class="mt-1">@_runLiveFinalTranscript <span class="text-cyan-400/80">@_runLiveInterimTranscript</span></p>
                                        </div>
                                    }

                                    @if (_runAudioByStep.TryGetValue(task.StepName, out var recordedAudio))
                                    {
                                        <div class="p-2 bg-gray-850 border border-gray-700 rounded">
                                            <div class="text-gray-200">@recordedAudio.FileName (@FormatFileSize(recordedAudio.Size))</div>
                                            @if (!string.IsNullOrWhiteSpace(recordedAudio.PreviewUrl))
                                            {
                                                <audio class="mt-1 w-full" controls src="@recordedAudio.PreviewUrl"></audio>
                                            }
                                        </div>
                                    }
                                </div>
                            }
                            else if (task.Kind == RunAssistantTaskKind.Transcript)
                            {
                                <textarea class="w-full h-36 p-2 bg-gray-850 border border-gray-700 rounded text-gray-200"
                                          @bind="_runTranscript"
                                          @bind:event="oninput"
                                          placeholder="Enter transcript text for this run..."></textarea>
                            }
                            else if (task.Kind == RunAssistantTaskKind.Review)
                            {
                                <textarea class="w-full h-28 p-2 bg-gray-850 border border-gray-700 rounded text-gray-200"
                                          value="@GetRunReviewText(task.StepName)"
                                          @oninput="(e => SetRunReviewText(task.StepName, e.Value?.ToString() ?? string.Empty))"
                                          placeholder="Review notes or edits..."></textarea>
                            }
                            else if (task.Kind == RunAssistantTaskKind.Questions)
                            {
                                <div class="space-y-2">
                                    <div class="flex gap-2">
                                        <button @onclick="GenerateRunQuestions"
                                                class="px-3 py-1 rounded bg-indigo-600 hover:bg-indigo-500 text-white">
                                            Generate from transcript
                                        </button>
                                        <button @onclick="AddRunQuestion"
                                                class="px-3 py-1 rounded border border-gray-600 text-gray-200 hover:text-white">
                                            Add question
                                        </button>
                                    </div>
                                    <div class="space-y-1">
                                        @for (var i = 0; i < _runQuestions.Count; i++)
                                        {
                                            var qIndex = i;
                                            <div class="flex gap-2">
                                                <input class="flex-1 px-2 py-1 bg-gray-850 border border-gray-700 rounded text-gray-200"
                                                       value="@_runQuestions[qIndex]"
                                                       @oninput="(e => SetRunQuestion(qIndex, e.Value?.ToString() ?? string.Empty))" />
                                                <button @onclick="() => RemoveRunQuestion(qIndex)"
                                                        class="px-2 py-1 rounded border border-red-700 text-red-300">
                                                    ✕
                                                </button>
                                            </div>
                                        }
                                    </div>
                                </div>
                            }
                            else if (task.Kind == RunAssistantTaskKind.QaAnswers)
                            {
                                <div class="space-y-2">
                                    @if (_runQaPairs.Count == 0)
                                    {
                                        <div class="text-gray-500">No Q/A pairs yet. Generate questions first.</div>
                                    }
                                    @for (var i = 0; i < _runQaPairs.Count; i++)
                                    {
                                        var qaIndex = i;
                                        <div class="p-2 border border-gray-700 rounded bg-gray-850 space-y-1">
                                            <input class="w-full px-2 py-1 bg-gray-900 border border-gray-700 rounded text-gray-200"
                                                   value="@_runQaPairs[qaIndex].Question"
                                                   @oninput="(e => SetRunQaQuestion(qaIndex, e.Value?.ToString() ?? string.Empty))"
                                                   placeholder="Question" />
                                            <textarea class="w-full h-20 p-2 bg-gray-900 border border-gray-700 rounded text-gray-200"
                                                      @oninput="(e => SetRunQaAnswer(qaIndex, e.Value?.ToString() ?? string.Empty))"
                                                      placeholder="Answer">@_runQaPairs[qaIndex].Answer</textarea>
                                        </div>
                                    }
                                </div>
                            }

                            <div class="flex items-center justify-between mt-3">
                                <button @onclick="GoToPreviousRunTask"
                                        disabled="@(_runAssistantIndex == 0)"
                                        class="px-3 py-1 rounded border border-gray-600 text-gray-200 disabled:opacity-40">
                                    Back
                                </button>

                                @if (_runAssistantIndex < _runAssistantTasks.Count - 1)
                                {
                                    <button @onclick="GoToNextRunTask"
                                            disabled="@(!CanAdvanceRunTask(task))"
                                            class="px-3 py-1 rounded bg-cyan-600 hover:bg-cyan-500 text-white disabled:opacity-40">
                                        Next
                                    </button>
                                }
                                else
                                {
                                    <button @onclick="RunWithAssistantInputsAsync"
                                            disabled="@(!CanAdvanceRunTask(task) || _runBusy)"
                                            class="px-3 py-1 rounded bg-green-600 hover:bg-green-500 text-white disabled:opacity-40">
                                        Start Workflow
                                    </button>
                                }
                            </div>
                        }
                    </div>
                }
            </div>
        }
    </div>
</div>

<TemplateBrowser IsVisible="_showTemplateBrowser"
                 OnClose="() => _showTemplateBrowser = false"
                 OnTemplateUsed="HandleTemplateUsed" />

<WorkflowListDialog IsVisible="_showOpenDialog"
                    OnClose="() => _showOpenDialog = false"
                    OnWorkflowSelected="HandleWorkflowOpened" />

<ShortcutsHelp IsVisible="_showShortcutsHelp"
               OnClose="() => _showShortcutsHelp = false" />

<ToastContainer />

@code {
    private bool _showShortcutsHelp;
    private bool _showSettings;
    private DotNetObjectReference<WorkflowDesigner>? _dotNetRef;
    private string _workflowName = "Untitled Workflow";
    private string? _currentWorkflowId;
    private bool _dirty;
    private string? _selectedNodeId;
    private string? _selectedNodeType;
    private Dictionary<string, object?> _selectedNodeConfig = new();
    private PropertiesPanel.NodeConnections? _selectedNodeConnections;
    private bool _showTemplateBrowser;
    private bool _showOpenDialog;
    private string? _activeRunId;
    private List<ValidationErrorDto> _validationErrors = [];
    private List<string> _logEntries = [];
    private string _activeBottomTab = "output";
    private bool _bottomPanelCollapsed;
    private StepListPanel? _stepListPanel;
    private bool _runAssistantActive;
    private int _runAssistantIndex;
    private readonly List<RunAssistantTask> _runAssistantTasks = [];
    private string _runTranscript = "";
    private string _runLiveFinalTranscript = "";
    private string _runLiveInterimTranscript = "";
    private bool _runRecorderSupported = true;
    private bool _runSpeechRecognitionSupported;
    private bool _runRecording;
    private bool _runBusy;
    private string? _runSelectedDeviceId;
    private readonly List<AudioDeviceOption> _runAudioDevices = [];
    private readonly Dictionary<string, BrowserAudioPayload> _runAudioByStep = new(StringComparer.OrdinalIgnoreCase);
    private readonly Dictionary<string, string> _runReviews = new(StringComparer.OrdinalIgnoreCase);
    private readonly List<string> _runQuestions = [];
    private readonly List<RunQaPair> _runQaPairs = [];
    private readonly Dictionary<string, string> _stepStatuses = new(StringComparer.OrdinalIgnoreCase);
    private readonly List<RunTimelineEntry> _runTimeline = [];
    private ExecutionHubClient? _executionHubClient;
    private string? _subscribedRunId;
    private CancellationTokenSource? _runPollingCts;
    private CancellationTokenSource? _runTickerCts;
    private string _runStatus = "Idle";
    private DateTimeOffset? _runStartedAt;
    private DateTimeOffset? _runCompletedAt;
    private TimeSpan _runElapsed = TimeSpan.Zero;
    private string? _activeStepName;
    private string? _runErrorMessage;
    private bool _runHubConnected;
    private RunSummary? _latestRunSummary;

    private int ValidationErrorCount => _validationErrors.Count(e => e.Severity == "Error");
    private int RunAssistantPendingCount => _runAssistantTasks.Count(t => !t.Completed);
    private RunAssistantTask? CurrentRunTask => _runAssistantTasks.Count == 0 || _runAssistantIndex < 0 || _runAssistantIndex >= _runAssistantTasks.Count
        ? null
        : _runAssistantTasks[_runAssistantIndex];
    private int CompletedStepCount => _stepStatuses.Count(s => s.Value.Equals("Completed", StringComparison.OrdinalIgnoreCase));
    private int FailedStepCount => _stepStatuses.Count(s => s.Value.Equals("Failed", StringComparison.OrdinalIgnoreCase));
    private int RunningStepCount => _stepStatuses.Count(s => s.Value.Equals("Running", StringComparison.OrdinalIgnoreCase));
    private int KnownStepCount => _stepStatuses.Count;
    private double RunProgressPercent => KnownStepCount == 0 ? 0 : Math.Clamp((double)(CompletedStepCount + FailedStepCount) / KnownStepCount * 100d, 0d, 100d);
    private string RunElapsedLabel => FormatDuration(_runElapsed);
    private string BottomPanelHeightClass => _activeBottomTab switch
    {
        "run" => "h-96",
        "output" => "h-80",
        "steps" => "h-72",
        _ => "h-40"
    };

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            _dotNetRef = DotNetObjectReference.Create(this);
            await JS.InvokeVoidAsync("workflowEditor.initialize", "workflow-canvas", _dotNetRef, Array.Empty<object>(), Array.Empty<object>());

            Shortcuts.Register("Ctrl+S", HandleSave);
            Shortcuts.Register("Ctrl+N", HandleNew);
            Shortcuts.Register("Ctrl+O", () => { _showOpenDialog = true; StateHasChanged(); return Task.CompletedTask; });
            Shortcuts.Register("Ctrl+Enter", HandleRun);
            Shortcuts.Register("Escape", () => { _showShortcutsHelp = false; _showOpenDialog = false; _showTemplateBrowser = false; _showSettings = false; _selectedNodeId = null; StateHasChanged(); return Task.CompletedTask; });
            Shortcuts.Register("Delete", () => JS.InvokeVoidAsync("workflowEditor.deleteSelected").AsTask());
            Shortcuts.Register("Backspace", () => JS.InvokeVoidAsync("workflowEditor.deleteSelected").AsTask());
            Shortcuts.OnShowHelp += () => { _showShortcutsHelp = true; InvokeAsync(StateHasChanged); return Task.CompletedTask; };
            await Shortcuts.InitializeAsync();

            try
            {
                _runSpeechRecognitionSupported = await JS.InvokeAsync<bool>("voiceRecorder.supportsSpeechRecognition");
                var devices = await JS.InvokeAsync<List<AudioDeviceOption>>("voiceRecorder.listInputDevices");
                _runAudioDevices.Clear();
                _runAudioDevices.AddRange(devices);
                _runSelectedDeviceId = _runAudioDevices.FirstOrDefault()?.DeviceId;
            }
            catch
            {
                _runRecorderSupported = false;
                _runSpeechRecognitionSupported = false;
            }
        }
    }

    [JSInvokable]
    public async void OnNodeSelected(string? nodeId, string? nodeType, Dictionary<string, object?>? config)
    {
        _selectedNodeId = nodeId;
        _selectedNodeType = nodeType;
        _selectedNodeConfig = config ?? new();

        if (nodeId is not null)
        {
            try
            {
                var connData = await JS.InvokeAsync<System.Text.Json.JsonElement>("workflowEditor.getNodeConnections", nodeId);
                _selectedNodeConnections = new PropertiesPanel.NodeConnections();
                if (connData.TryGetProperty("inputs", out var inputs))
                {
                    foreach (var item in inputs.EnumerateArray())
                    {
                        _selectedNodeConnections.Inputs.Add(new PropertiesPanel.ConnectionInfo
                        {
                            Id = item.GetProperty("id").GetString() ?? "",
                            Label = item.GetProperty("label").GetString() ?? "",
                            EdgeLabel = item.TryGetProperty("edgeLabel", out var el) && el.ValueKind != System.Text.Json.JsonValueKind.Null ? el.GetString() : null
                        });
                    }
                }
                if (connData.TryGetProperty("outputs", out var outputs))
                {
                    foreach (var item in outputs.EnumerateArray())
                    {
                        _selectedNodeConnections.Outputs.Add(new PropertiesPanel.ConnectionInfo
                        {
                            Id = item.GetProperty("id").GetString() ?? "",
                            Label = item.GetProperty("label").GetString() ?? "",
                            EdgeLabel = item.TryGetProperty("edgeLabel", out var el) && el.ValueKind != System.Text.Json.JsonValueKind.Null ? el.GetString() : null
                        });
                    }
                }
            }
            catch { _selectedNodeConnections = null; }
        }
        else
        {
            _selectedNodeConnections = null;
        }

        StateHasChanged();
    }

    [JSInvokable]
    public void OnNodeAdded(string nodeId, string nodeType, double x, double y)
    {
        _dirty = true;
        StateHasChanged();
    }

    [JSInvokable]
    public void OnNodeRemoved(string nodeId)
    {
        if (_selectedNodeId == nodeId) { _selectedNodeId = null; _selectedNodeType = null; _selectedNodeConnections = null; }
        _dirty = true;
        StateHasChanged();
    }

    [JSInvokable]
    public void OnEdgeCreated(string sourceId, string targetId) { _dirty = true; StateHasChanged(); }

    [JSInvokable]
    public void OnEdgeRemoved(string edgeId) { _dirty = true; StateHasChanged(); }

    [JSInvokable]
    public void OnCanvasChanged() { _dirty = true; StateHasChanged(); }

    [JSInvokable]
    public Task OnSelectionChanged(string[]? selectedNodeIds)
    {
        // React Flow emits selection updates separately from click events.
        // We only need a no-throw interop target plus clear panel state when empty.
        if (selectedNodeIds is null || selectedNodeIds.Length == 0)
        {
            _selectedNodeConnections = null;
        }

        return Task.CompletedTask;
    }

    [JSInvokable]
    public Task OnLiveTranscriptUpdated(string finalText, string interimText)
    {
        _runLiveFinalTranscript = finalText ?? "";
        _runLiveInterimTranscript = interimText ?? "";

        if (CurrentRunTask?.Kind is RunAssistantTaskKind.Record or RunAssistantTaskKind.Transcript)
        {
            if (string.IsNullOrWhiteSpace(_runTranscript) || _runRecording)
                _runTranscript = $"{_runLiveFinalTranscript} {_runLiveInterimTranscript}".Trim();
        }

        StateHasChanged();
        return Task.CompletedTask;
    }

