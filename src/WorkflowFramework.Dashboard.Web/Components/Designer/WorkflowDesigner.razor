    private async Task LoadDefinitionIntoCanvas(WorkflowDefinitionDto definition)
    {
        var canvas = definition.Canvas is { Nodes.Count: > 0 } savedCanvas
            ? savedCanvas
            : BuildCanvasGraph(definition);

        var nodes = canvas.Nodes
            .Select(node => new
            {
                id = node.Id,
                type = node.Type,
                label = node.Label,
                icon = node.Icon ?? "⬡",
                category = node.Category ?? string.Empty,
                color = node.Color ?? "#4b5563",
                x = node.X,
                y = node.Y,
                config = node.Config?.ToDictionary(k => k.Key, k => (object?)k.Value) ?? new Dictionary<string, object?>()
            })
            .ToArray();

        var edges = canvas.Edges
            .Select(edge => new
            {
                id = edge.Id,
                sourceHandle = edge.Kind,
                kind = edge.Kind,
                source = edge.Source,
                target = edge.Target,
                label = edge.Label
            })
            .ToArray();

        await JS.InvokeVoidAsync("workflowEditor.setWorkflowDefinition", nodes, edges);
        await JS.InvokeVoidAsync("workflowEditor.fitView");
        _activeBottomTab = "steps";
        _bottomPanelCollapsed = false;
        StateHasChanged();
        RefreshStepList();
    }

    private static WorkflowCanvasDto BuildCanvasGraph(WorkflowDefinitionDto definition)
    {
        var nodes = new List<WorkflowCanvasNodeDto>();
        var edges = new List<WorkflowCanvasEdgeDto>();
        int nodeCounter = 0;
        int edgeCounter = 0;

        string NextId() => $"node_{++nodeCounter}";

        static (string category, string color, string icon) GetStepVisuals(string type) => type.ToLowerInvariant() switch
        {
            "action" => ("Core", "#3b82f6", "⬡"),
            "conditional" => ("Core", "#3b82f6", "◇"),
            "parallel" => ("Core", "#3b82f6", "⫘"),
            "foreach" or "while" or "dowhile" => ("Core", "#3b82f6", "↻"),
            "retry" => ("Core", "#3b82f6", "🔄"),
            "trycatch" => ("Core", "#3b82f6", "🛡"),
            "timeout" => ("Core", "#3b82f6", "⏱"),
            "delay" => ("Core", "#3b82f6", "⏱"),
            "saga" => ("Core", "#3b82f6", "📜"),
            "contentbasedrouter" or "messagefilter" or "splitter" or "aggregator"
                or "recipientlist" or "wiretap" or "deadletterchannel" or "enricher"
                or "normalizer" or "claimcheck" or "dynamicrouter" or "routingslip"
                => ("Integration", "#22c55e", "🔀"),
            "httpstep" => ("HTTP", "#14b8a6", "🌐"),
            "llmcallstep" or "agentdecisionstep" or "agentplanstep" => ("AI/Agents", "#a855f7", "🤖"),
            "agentloopstep" or "toolcallstep" => ("AI/Agents", "#a855f7", "🧠"),
            "datamapstep" or "validatestep" or "schemavalidatestep" => ("Data", "#f97316", "🗺"),
            "publisheventstep" or "subscribeeventstep" => ("Events", "#eab308", "⚡"),
            "humantaskstep" or "approvalstep" => ("Human Tasks", "#ec4899", "✅"),
            _ => ("Core", "#3b82f6", "⬡")
        };

        void AddEdge(string source, string target, string? label = null, string? kind = null)
        {
            edges.Add(new WorkflowCanvasEdgeDto
            {
                Id = $"edge_{++edgeCounter}",
                Kind = kind,
                Source = source,
                Target = target,
                Label = label
            });
        }

        string AddSyntheticExitNode(string ownerId, double x, double y, string label)
        {
            var exitId = NextId();
            nodes.Add(new WorkflowCanvasNodeDto
            {
                Id = exitId,
                Type = "action",
                Label = label,
                Icon = "↪",
                Category = "Core",
                Color = "#6b7280",
                X = x,
                Y = y,
                Config = new Dictionary<string, string>
                {
                    ["__syntheticKind"] = "container-exit",
                    ["__ownerId"] = ownerId
                }
            });

            return exitId;
        }

        (string entryId, string exitId) LayoutStep(StepDefinitionApiDto step, double x, double y)
        {
            var (cat, color, icon) = GetStepVisuals(step.Type);
            var nodeId = NextId();

            Dictionary<string, string> ToNodeConfig(StepDefinitionApiDto s) =>
                (s.Config ?? new Dictionary<string, string>())
                .Concat(new[] { new KeyValuePair<string, string>("label", s.Name) })
                .Concat(s.MaxAttempts > 0 ? [new KeyValuePair<string, string>("maxAttempts", s.MaxAttempts.ToString(System.Globalization.CultureInfo.InvariantCulture))] : [])
                .Concat(s.TimeoutSeconds > 0 ? [new KeyValuePair<string, string>("timeoutSeconds", s.TimeoutSeconds.ToString(System.Globalization.CultureInfo.InvariantCulture))] : [])
                .Concat(s.DelaySeconds > 0 ? [new KeyValuePair<string, string>("delaySeconds", s.DelaySeconds.ToString(System.Globalization.CultureInfo.InvariantCulture))] : [])
                .Concat(!string.IsNullOrWhiteSpace(s.SubWorkflowName) ? [new KeyValuePair<string, string>("subWorkflowName", s.SubWorkflowName!)] : [])
                .Concat(s.CatchTypes is { Count: > 0 } ? [new KeyValuePair<string, string>("catchTypes", string.Join(",", s.CatchTypes))] : [])
                .Concat(s.Type.Equals("Parallel", StringComparison.OrdinalIgnoreCase) && s.Steps is { Count: > 0 }
                    ? [new KeyValuePair<string, string>("__parallelBranchCount", s.Steps.Count.ToString(System.Globalization.CultureInfo.InvariantCulture))]
                    : [])
                .GroupBy(pair => pair.Key, StringComparer.Ordinal)
                .ToDictionary(group => group.Key, group => group.Last().Value, StringComparer.Ordinal);

            nodes.Add(new WorkflowCanvasNodeDto
            {
                Id = nodeId,
                Type = step.Type,
                Label = step.Name,
                Icon = icon,
                Category = cat,
                Color = color,
                X = x,
                Y = y,
                Config = ToNodeConfig(step)
            });

            if (step.Type.Equals("Conditional", StringComparison.OrdinalIgnoreCase))
            {
                var mergeId = AddSyntheticExitNode(nodeId, x + 400, y, step.Else is not null ? "↪ Merge" : "↪ Continue");

                if (step.Then is not null)
                {
                    var (thenEntry, thenExit) = LayoutStep(step.Then, x + 200, y - 60);
                    AddEdge(nodeId, thenEntry, "then", "then");
                    AddEdge(thenExit, mergeId);
                }
                if (step.Else is not null)
                {
                    var (elseEntry, elseExit) = LayoutStep(step.Else, x + 200, y + 60);
                    AddEdge(nodeId, elseEntry, "else", "else");
                    AddEdge(elseExit, mergeId);
                }
                else
                {
                    AddEdge(nodeId, mergeId, kind: "continue");
                }

                return (nodeId, mergeId);
            }

            if (step.Type.Equals("Parallel", StringComparison.OrdinalIgnoreCase) && step.Steps is { Count: > 0 })
            {
                var joinId = AddSyntheticExitNode(nodeId, x + 400, y, "↪ Join");
                double branchY = y - ((step.Steps.Count - 1) * 40.0);
                var branchExits = new List<string>();
                var branchIndex = 1;

                foreach (var child in step.Steps)
                {
                    var (childEntry, childExit) = LayoutStep(child, x + 200, branchY);
                    AddEdge(nodeId, childEntry, kind: $"output-{branchIndex++}");
                    branchExits.Add(childExit);
                    branchY += 80;
                }

                foreach (var exit in branchExits) AddEdge(exit, joinId);
                return (nodeId, joinId);
            }

            if (step.Type.Equals("Timeout", StringComparison.OrdinalIgnoreCase) && step.Inner is not null)
            {
                var exitId = AddSyntheticExitNode(nodeId, x + 400, y, "↪ Continue");
                var (innerEntry, innerExit) = LayoutStep(step.Inner, x + 200, y);
                AddEdge(nodeId, innerEntry, kind: "inner");
                AddEdge(innerExit, exitId);
                return (nodeId, exitId);
            }

            if ((step.Type.Equals("Retry", StringComparison.OrdinalIgnoreCase)
                || step.Type.Equals("ForEach", StringComparison.OrdinalIgnoreCase)
                || step.Type.Equals("While", StringComparison.OrdinalIgnoreCase)
                || step.Type.Equals("DoWhile", StringComparison.OrdinalIgnoreCase)
                || step.Type.Equals("Saga", StringComparison.OrdinalIgnoreCase))
                && step.Steps is { Count: > 0 })
            {
                string? lastChild = null;
                double childX = x + 200;
                foreach (var child in step.Steps)
                {
                    var (childEntry, childExit) = LayoutStep(child, childX, y);
                    AddEdge(lastChild ?? nodeId, childEntry, kind: lastChild is null ? "body" : null);
                    lastChild = childExit;
                    childX += 200;
                }

                var exitId = AddSyntheticExitNode(nodeId, childX, y, "↪ Continue");
                if (lastChild is not null)
                    AddEdge(lastChild, exitId);
                return (nodeId, exitId);
            }

            if (step.Type.Equals("TryCatch", StringComparison.OrdinalIgnoreCase) && step.TryBody is { Count: > 0 })
            {
                string? lastTry = null;
                double childX = x + 200;
                foreach (var child in step.TryBody)
                {
                    var (childEntry, childExit) = LayoutStep(child, childX, y);
                    AddEdge(lastTry ?? nodeId, childEntry, kind: lastTry is null ? "try" : null);
                    lastTry = childExit;
                    childX += 200;
                }

                string? lastFinally = null;
                if (step.FinallyBody is { Count: > 0 })
                {
                    foreach (var fin in step.FinallyBody)
                    {
                        var (finEntry, finExit) = LayoutStep(fin, childX, y + 80);
                        AddEdge(lastFinally ?? lastTry ?? nodeId, finEntry, kind: lastFinally is null ? "finally" : null);
                        lastFinally = finExit;
                        childX += 200;
                    }
                }

                var exitId = AddSyntheticExitNode(nodeId, childX, y, "↪ Continue");
                AddEdge(lastFinally ?? lastTry ?? nodeId, exitId);
                return (nodeId, exitId);
            }

            return (nodeId, nodeId);
        }

        double currentX = 0;
        string? previousExit = null;

        foreach (var step in definition.Steps)
        {
            var (entryId, exitId) = LayoutStep(step, currentX, 100);
            if (previousExit is not null)
                AddEdge(previousExit, entryId);
            previousExit = exitId;

            currentX += step.Steps?.Count > 0 || step.Then is not null || step.Else is not null || step.Inner is not null || step.TryBody?.Count > 0 || step.FinallyBody?.Count > 0
                ? 600
                : 200;
        }

        return new WorkflowCanvasDto
        {
            Nodes = nodes,
            Edges = edges
        };
    }

    private static (List<CanvasNode> Nodes, List<CanvasEdge> Edges) ParseCanvasGraph(System.Text.Json.JsonElement canvasData)
    {
        if (!canvasData.TryGetProperty("nodes", out var nodesEl) || !canvasData.TryGetProperty("edges", out var edgesEl))
            return ([], []);

        var nodes = new List<CanvasNode>();
        foreach (var nodeElement in nodesEl.EnumerateArray())
        {
            var config = new Dictionary<string, string>(StringComparer.Ordinal);
            if (nodeElement.TryGetProperty("config", out var cfg) && cfg.ValueKind == System.Text.Json.JsonValueKind.Object)
            {
                foreach (var prop in cfg.EnumerateObject())
                {
                    config[prop.Name] = prop.Value.ValueKind == System.Text.Json.JsonValueKind.String
                        ? prop.Value.GetString() ?? string.Empty
                        : prop.Value.GetRawText();
                }
            }

            var rawLabel = nodeElement.TryGetProperty("label", out var labelElement)
                ? labelElement.GetString() ?? string.Empty
                : string.Empty;

            nodes.Add(new CanvasNode
            {
                Id = nodeElement.GetProperty("id").GetString() ?? string.Empty,
                Type = nodeElement.TryGetProperty("type", out var typeElement) ? typeElement.GetString() ?? "Action" : "Action",
                Label = ResolveNodeLabel(rawLabel, config),
                Icon = nodeElement.TryGetProperty("icon", out var iconElement) && iconElement.ValueKind == System.Text.Json.JsonValueKind.String ? iconElement.GetString() : null,
                Category = nodeElement.TryGetProperty("category", out var categoryElement) && categoryElement.ValueKind == System.Text.Json.JsonValueKind.String ? categoryElement.GetString() : null,
                Color = nodeElement.TryGetProperty("color", out var colorElement) && colorElement.ValueKind == System.Text.Json.JsonValueKind.String ? colorElement.GetString() : null,
                X = nodeElement.TryGetProperty("x", out var xElement) && xElement.TryGetDouble(out var x) ? x : 0,
                Y = nodeElement.TryGetProperty("y", out var yElement) && yElement.TryGetDouble(out var y) ? y : 0,
                Config = config
            });
        }

        var edges = new List<CanvasEdge>();
        foreach (var edgeElement in edgesEl.EnumerateArray())
        {
            edges.Add(new CanvasEdge
            {
                Id = edgeElement.TryGetProperty("id", out var idElement) && idElement.ValueKind == System.Text.Json.JsonValueKind.String ? idElement.GetString() : null,
                Kind =
                    edgeElement.TryGetProperty("kind", out var kindElement) && kindElement.ValueKind == System.Text.Json.JsonValueKind.String
                        ? kindElement.GetString()
                        : edgeElement.TryGetProperty("sourceHandle", out var sourceHandleElement) && sourceHandleElement.ValueKind == System.Text.Json.JsonValueKind.String
                            ? sourceHandleElement.GetString()
                            : null,
                Source = edgeElement.GetProperty("source").GetString() ?? string.Empty,
                Target = edgeElement.GetProperty("target").GetString() ?? string.Empty,
                Label = edgeElement.TryGetProperty("label", out var edgeLabelElement) && edgeLabelElement.ValueKind == System.Text.Json.JsonValueKind.String ? edgeLabelElement.GetString() : null
            });
        }

        return (nodes, edges);
    }

    private static WorkflowCanvasDto? CreateCanvasSnapshot(IReadOnlyList<CanvasNode> nodes, IReadOnlyList<CanvasEdge> edges)
    {
        if (nodes.Count == 0 && edges.Count == 0)
            return null;

        return new WorkflowCanvasDto
        {
            Nodes = nodes
                .Select(node => new WorkflowCanvasNodeDto
                {
                    Id = node.Id,
                    Type = node.Type,
                    Label = node.Label,
                    Icon = node.Icon,
                    Category = node.Category,
                    Color = node.Color,
                    X = node.X,
                    Y = node.Y,
                    Config = node.Config.Count > 0 ? new Dictionary<string, string>(node.Config, StringComparer.Ordinal) : null
                })
                .ToList(),
            Edges = edges
                .Select(edge => new WorkflowCanvasEdgeDto
                {
                    Id = edge.Id,
                    Kind = edge.Kind,
                    Source = edge.Source,
                    Target = edge.Target,
                    Label = edge.Label
                })
                .ToList()
        };
    }

    private static string ResolveNodeLabel(string rawLabel, IReadOnlyDictionary<string, string> config)
        => config.TryGetValue("label", out var configuredLabel) && !string.IsNullOrWhiteSpace(configuredLabel)
            ? configuredLabel
            : rawLabel;

    private static IReadOnlyList<PropertiesPanel.VariableReferenceInfo> BuildAvailableVariables(System.Text.Json.JsonElement canvasData, string? selectedNodeId)
    {
        if (string.IsNullOrWhiteSpace(selectedNodeId))
            return [];

        var (nodes, edges) = ParseCanvasGraph(canvasData);
        if (nodes.Count == 0)
            return CreateDefaultRunInputVariables();

        static bool IsSynthetic(CanvasNode node)
            => string.Equals(node.Config.GetValueOrDefault("__syntheticKind"), "container-exit", StringComparison.Ordinal);

        var reverseEdges = edges.GroupBy(edge => edge.Target)
            .ToDictionary(group => group.Key, group => group.Select(edge => edge.Source).ToList(), StringComparer.Ordinal);

        var reachable = new HashSet<string>(StringComparer.Ordinal);
        var pending = new Stack<string>();
        pending.Push(selectedNodeId);

        while (pending.Count > 0)
        {
            var current = pending.Pop();
            if (!reverseEdges.TryGetValue(current, out var upstreamIds))
                continue;

            foreach (var upstreamId in upstreamIds)
            {
                if (!reachable.Add(upstreamId))
                    continue;

                pending.Push(upstreamId);
            }
        }

        var variables = CreateDefaultRunInputVariables().ToList();
        foreach (var node in nodes)
        {
            if (string.Equals(node.Id, selectedNodeId, StringComparison.Ordinal) || IsSynthetic(node) || !reachable.Contains(node.Id))
                continue;

            foreach (var output in GetVariableOutputs(node.Type, node.Label))
                variables.Add(output);
        }

        return variables;
    }

    private static IReadOnlyList<PropertiesPanel.VariableReferenceInfo> CreateDefaultRunInputVariables()
    {
        return
        [
            new() { GroupLabel = "Run inputs", Token = "{transcript}", Description = "Transcript captured in the Run Assistant." },
            new() { GroupLabel = "Run inputs", Token = "{questions}", Description = "Question list supplied from the Run Assistant." },
            new() { GroupLabel = "Run inputs", Token = "{qaPairs}", Description = "Question-and-answer pairs supplied from the Run Assistant." },
            new() { GroupLabel = "Run inputs", Token = "{recordings}", Description = "Audio recording payloads captured for run steps." }
        ];
    }

    private static IReadOnlyList<PropertiesPanel.VariableReferenceInfo> GetVariableOutputs(string type, string stepName)
    {
        if (string.IsNullOrWhiteSpace(stepName))
            return [];

        static PropertiesPanel.VariableReferenceInfo Output(string name, string step, string description)
            => new()
            {
                GroupLabel = step,
                Token = $"{{{{{step}.{name}}}}}",
                Description = description
            };

        return (type ?? string.Empty).Trim().ToLowerInvariant() switch
        {
            "action" =>
            [
                Output("Output", stepName, "Rendered output text from the action step."),
                Output("Expression", stepName, "Final rendered expression string.")
            ],
            "llmcallstep" =>
            [
                Output("Response", stepName, "LLM response text."),
                Output("FinishReason", stepName, "Provider finish reason."),
                Output("TotalTokens", stepName, "Token usage reported by the provider.")
            ],
            "agentdecisionstep" =>
            [
                Output("Decision", stepName, "Decision selected by the agent.")
            ],
            "agentplanstep" =>
            [
                Output("Plan", stepName, "Generated plan content."),
                Output("FinishReason", stepName, "Provider finish reason."),
                Output("TotalTokens", stepName, "Token usage reported by the provider.")
            ],
            "agentloopstep" =>
            [
                Output("Response", stepName, "Final agent response."),
                Output("Iterations", stepName, "Number of loop iterations."),
                Output("ToolResults", stepName, "Tool call results captured during the loop.")
            ],
            "httpstep" =>
            [
                Output("StatusCode", stepName, "HTTP status code."),
                Output("Body", stepName, "HTTP response body."),
                Output("IsSuccess", stepName, "Whether the response status code was successful.")
            ],
            "toolcallstep" =>
            [
                Output("Result", stepName, "Tool invocation result content.")
            ],
            "humantaskstep" or "approvalstep" =>
            [
                Output("Status", stepName, "Human task completion status.")
            ],
            "webhooktriggerstep" =>
            [
                Output("CallbackId", stepName, "Generated callback identifier."),
                Output("Received", stepName, "Whether a webhook payload was received."),
                Output("Body", stepName, "Received webhook body.")
            ],
            _ =>
            [
                Output("Output", stepName, "Default step output value.")
            ]
        };
    }

    private async Task HandleStepStatusChanged((string StepName, string Status) stepStatus)
    {
        if (!string.IsNullOrWhiteSpace(stepStatus.StepName))
            _stepStatuses[stepStatus.StepName] = stepStatus.Status;

        try
        {
            await JS.InvokeVoidAsync("workflowEditor.updateNodeStatus", stepStatus.StepName, stepStatus.Status);
        }
        catch { }
    }

    private void HandleRunStatusChanged(string status)
    {
        _ = HandleRunStatusChangedAsync(status, emitTimeline: true);
    }

    private static string GetLogClass(string entry) => entry switch
    {
        _ when entry.Contains("❌") || entry.Contains("💥") => "text-red-400",
        _ when entry.Contains("✅") || entry.Contains("🏁") => "text-green-400",
        _ when entry.Contains("⏳") => "text-yellow-400",
        _ => ""
    };

    private string GetRunStatusBadgeClass() => _runStatus switch
    {
        "Running" => "run-badge-running",
        "Completed" => "run-badge-completed",
        "Failed" => "run-badge-failed",
        "Cancelled" => "run-badge-cancelled",
        _ => "run-badge-idle"
    };

    private static string GetTimelineKindForStatus(string status) => status switch
    {
        "Running" => "running",
        "Completed" => "success",
        "Failed" => "error",
        "Cancelled" => "warn",
        _ => "info"
    };

    private static string GetRunEventRowClass(string kind) => kind switch
    {
        "running" => "run-event-running",
        "success" => "run-event-success",
        "warn" => "run-event-warn",
        "error" => "run-event-error",
        _ => "run-event-info"
    };

    private static string TrimForRunEvent(string value)
    {
        const int max = 140;
        if (string.IsNullOrWhiteSpace(value))
            return string.Empty;
        return value.Length <= max ? value : $"{value[..max].TrimEnd()}...";
    }

    private static string FormatDuration(TimeSpan duration)
    {
        if (duration.TotalSeconds < 1)
            return $"{Math.Max(duration.TotalMilliseconds, 0):0} ms";
        if (duration.TotalMinutes < 1)
            return $"{duration.TotalSeconds:0.0}s";
        if (duration.TotalHours < 1)
            return $"{(int)duration.TotalMinutes:D2}:{duration.Seconds:D2}";
        return $"{(int)duration.TotalHours:D2}:{duration.Minutes:D2}:{duration.Seconds:D2}";
    }

    private static string GetSeverityIcon(string severity) => severity switch
    {
        "Error" => "🔴",
        "Warning" => "🟡",
        "Info" => "🔵",
        _ => "⚪"
    };

    private static string GetSeverityClass(string severity) => severity switch
    {
        "Error" => "text-red-400",
        "Warning" => "text-yellow-400",
        "Info" => "text-blue-400",
        _ => "text-gray-400"
    };

    public async ValueTask DisposeAsync()
    {
        await StopRunTrackingAsync();
        _dotNetRef?.Dispose();
        try { await Shortcuts.DisposeAsync(); } catch { }
        try { await JS.InvokeVoidAsync("voiceRecorder.dispose"); } catch { }
        try { await JS.InvokeVoidAsync("workflowEditor.destroy"); } catch { }
    }
