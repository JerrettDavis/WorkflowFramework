    private async Task HandleNew()
    {
        await CancelRunAssistant();
        await StopRunTrackingAsync(clearHistory: true);
        _workflowName = "Untitled Workflow";
        _currentWorkflowId = null;
        _dirty = false;
        _selectedNodeId = null;
        _selectedNodeType = null;
        _selectedNodeConnections = null;
        _selectedNodeVariables = [];
        _activeRunId = null;
        await JS.InvokeVoidAsync("workflowEditor.setWorkflowDefinition", Array.Empty<object>(), Array.Empty<object>());
    }

    private async Task HandleSave()
    {
        try
        {
            var canvasData = await JS.InvokeAsync<System.Text.Json.JsonElement>("workflowEditor.getWorkflowDefinition");
            var request = new CreateWorkflowRequest
            {
                Description = null,
                Definition = CanvasToDefinition(canvasData)
            };

            SavedWorkflowDefinition? result;
            if (_currentWorkflowId is not null)
                result = await Api.UpdateWorkflowAsync(_currentWorkflowId, request);
            else
                result = await Api.SaveWorkflowAsync(request);

            if (result is not null)
            {
                _currentWorkflowId = result.Id;
                _dirty = false;
                _logEntries.Add($"[{DateTime.Now:HH:mm:ss}] Saved workflow: {_workflowName} (id: {result.Id})");
                Toast.Success($"Saved '{_workflowName}'");
            }
        }
        catch (Exception ex)
        {
            _logEntries.Add($"[{DateTime.Now:HH:mm:ss}] Save failed: {ex.Message}");
            Toast.Error($"Save failed: {ex.Message}");
        }
    }

    private async Task HandleValidate()
    {
        try
        {
            var canvasData = await JS.InvokeAsync<System.Text.Json.JsonElement>("workflowEditor.getWorkflowDefinition");
            var definition = CanvasToDefinition(canvasData);
            var result = _currentWorkflowId is not null
                ? await Api.ValidateWorkflowDraftAsync(_currentWorkflowId, definition)
                : await Api.ValidateDefinitionAsync(definition);
            _validationErrors = result?.Errors ?? [];

            if (_validationErrors.Count == 0)
                _logEntries.Add($"[{DateTime.Now:HH:mm:ss}] ✅ Validation passed");
            else
                _logEntries.Add($"[{DateTime.Now:HH:mm:ss}] Validation: {_validationErrors.Count(e => e.Severity == "Error")} error(s), {_validationErrors.Count(e => e.Severity == "Warning")} warning(s)");
        }
        catch (Exception ex)
        {
            _logEntries.Add($"[{DateTime.Now:HH:mm:ss}] Validation failed: {ex.Message}");
        }
    }

    private async Task HandleValidationErrorClicked(string? stepName)
    {
        if (stepName is not null)
        {
            await JS.InvokeVoidAsync("workflowEditor.selectNodeByName", stepName);
        }
    }

    private async Task HandleRun()
    {
        await HandleValidate();
        if (_validationErrors.Any(e => e.Severity == "Error"))
        {
            _logEntries.Add($"[{DateTime.Now:HH:mm:ss}] ❌ Cannot run: fix validation errors first");
            return;
        }

        if (_currentWorkflowId is null || _dirty)
        {
            await HandleSave();
            if (_currentWorkflowId is null)
            {
                _logEntries.Add($"[{DateTime.Now:HH:mm:ss}] Cannot run: workflow not saved");
                return;
            }
        }

        try
        {
            var canvasData = await JS.InvokeAsync<System.Text.Json.JsonElement>("workflowEditor.getWorkflowDefinition");
            var definition = CanvasToDefinition(canvasData);
            var runTasks = BuildRunAssistantTasks(definition);

            if (runTasks.Count > 0)
            {
                InitializeRunAssistant(runTasks);
                _activeBottomTab = "run";
                _bottomPanelCollapsed = false;
                _logEntries.Add($"[{DateTime.Now:HH:mm:ss}] Opened run assistant with {runTasks.Count} interactive task(s)");
                Toast.Info("Run assistant opened");
                return;
            }

            await StartWorkflowRunAsync();
        }
        catch (Exception ex)
        {
            _logEntries.Add($"[{DateTime.Now:HH:mm:ss}] Run failed: {ex.Message}");
            Toast.Error($"Run failed: {ex.Message}");
        }
    }

    private async Task StartWorkflowRunAsync(StartRunRequestDto? request = null)
    {
        if (_currentWorkflowId is null)
            return;

        _activeBottomTab = "output";
        _bottomPanelCollapsed = false;
        await SeedStepStatusesFromCanvasAsync();

        _logEntries.Add($"[{DateTime.Now:HH:mm:ss}] Running workflow: {_workflowName}...");
        var run = await Api.RunWorkflowAsync(_currentWorkflowId, request);
        if (run is not null)
        {
            _activeRunId = run.RunId;
            _latestRunSummary = run;
            if (request?.Inputs is { Count: > 0 })
            {
                var recordingsCount = _runAudioByStep.Count;
                var questionsCount = _runQuestions.Count(q => !string.IsNullOrWhiteSpace(q));
                _logEntries.Add($"[{DateTime.Now:HH:mm:ss}] Run payload prepared: {recordingsCount} audio clip(s), transcript {(_runTranscript.Length > 0 ? "included" : "empty")}, {questionsCount} question(s).");
            }
            _logEntries.Add($"[{DateTime.Now:HH:mm:ss}] Run started: {run.RunId} (status: {run.Status})");
            if (!string.IsNullOrWhiteSpace(run.Source))
                _logEntries.Add($"[{DateTime.Now:HH:mm:ss}] Source: {run.Source}");
            Toast.Info($"Run started: {run.RunId}");

            await BeginRunTrackingAsync(run);
        }
    }

    private async Task SeedStepStatusesFromCanvasAsync()
    {
        try
        {
            var canvasData = await JS.InvokeAsync<System.Text.Json.JsonElement>("workflowEditor.getWorkflowDefinition");
            var definition = CanvasToDefinition(canvasData);
            var stepNames = FlattenSteps(definition.Steps)
                .Select(s => s.Name)
                .Where(n => !string.IsNullOrWhiteSpace(n))
                .Distinct(StringComparer.OrdinalIgnoreCase)
                .ToList();

            if (stepNames.Count == 0 && !string.IsNullOrWhiteSpace(_currentWorkflowId))
            {
                var saved = await Api.GetWorkflowAsync(_currentWorkflowId);
                if (saved?.Definition is not null)
                {
                    stepNames = FlattenSteps(saved.Definition.Steps)
                        .Select(s => s.Name)
                        .Where(n => !string.IsNullOrWhiteSpace(n))
                        .Distinct(StringComparer.OrdinalIgnoreCase)
                        .ToList();
                }
            }

            _stepStatuses.Clear();
            foreach (var stepName in stepNames)
                _stepStatuses[stepName] = "Queued";
        }
        catch
        {
            // Best-effort hinting only.
        }
    }

    private async Task CancelActiveRunAsync()
    {
        if (string.IsNullOrWhiteSpace(_activeRunId))
            return;

        var runId = _activeRunId;
        try
        {
            var cancelled = await Api.CancelRunAsync(runId);
            if (!cancelled)
            {
                _logEntries.Add($"[{DateTime.Now:HH:mm:ss}] Cancel request ignored: run {runId} was not active.");
                return;
            }

            _logEntries.Add($"[{DateTime.Now:HH:mm:ss}] Cancel requested for run {runId}.");
            AddRunTimeline("warn", "Cancellation requested", "Run cancellation was requested from the dashboard.");
            await HandleRunStatusChangedAsync("Cancelled", emitTimeline: true);
            Toast.Info("Run cancelled");
        }
        catch (Exception ex)
        {
            _logEntries.Add($"[{DateTime.Now:HH:mm:ss}] Cancel failed: {ex.Message}");
            Toast.Error($"Cancel failed: {ex.Message}");
        }
    }

    private async Task BeginRunTrackingAsync(RunSummary run)
    {
        await StopRunTrackingAsync(clearHistory: false);

        _activeRunId = run.RunId;
        _runStatus = string.IsNullOrWhiteSpace(run.Status) ? "Running" : run.Status;
        _runStartedAt = run.StartedAt == default ? DateTimeOffset.UtcNow : run.StartedAt;
        _runCompletedAt = run.CompletedAt;
        _runElapsed = (_runCompletedAt ?? DateTimeOffset.UtcNow) - _runStartedAt.Value;
        _runErrorMessage = run.Error;
        _latestRunSummary = run;
        _runTimeline.Clear();

        AddRunTimeline("info", "Run requested", $"Tracking run {run.RunId[..Math.Min(10, run.RunId.Length)]}.");
        if (KnownStepCount > 0)
            AddRunTimeline("info", "Workflow mapped", $"{KnownStepCount} known step(s) primed for tracking.");
        StartRunElapsedTicker();
        StartRunPolling(run.RunId);
        await ConnectRunSignalRAsync(run.RunId);
    }

    private async Task ConnectRunSignalRAsync(string runId)
    {
        var hubUrls = Api.GetExecutionHubUrls();
        if (hubUrls.Count == 0)
        {
            _runHubConnected = false;
            AddRunTimeline("warn", "Realtime unavailable", "Service-discovery URL is not directly usable for SignalR. Using API polling.");
            _logEntries.Add($"[{DateTime.Now:HH:mm:ss}] SignalR unavailable: unsupported hub URL scheme; polling enabled.");
            return;
        }

        Exception? lastError = null;
        foreach (var hubUrl in hubUrls)
        {
            ExecutionHubClient? candidate = null;
            try
            {
                candidate = CreateExecutionHubClient(hubUrl);
                await candidate.SubscribeToRunAsync(runId);
                _executionHubClient = candidate;
                _subscribedRunId = runId;
                _runHubConnected = true;
                AddRunTimeline("success", "Realtime connected", $"SignalR stream is active ({hubUrl}).");
                _logEntries.Add($"[{DateTime.Now:HH:mm:ss}] SignalR connected: {hubUrl}");
                return;
            }
            catch (Exception ex)
            {
                lastError = ex;
                _logEntries.Add($"[{DateTime.Now:HH:mm:ss}] SignalR connection failed ({hubUrl}): {ex.Message}");
                if (candidate is not null)
                {
                    try { await candidate.DisposeAsync(); } catch { }
                }
            }
        }

        _runHubConnected = false;
        AddRunTimeline("warn", "Realtime unavailable", "Using API polling fallback.");
        if (lastError is not null)
            _logEntries.Add($"[{DateTime.Now:HH:mm:ss}] SignalR unavailable: {lastError.Message}");
    }

    private ExecutionHubClient CreateExecutionHubClient(string hubUrl)
    {
        var client = new ExecutionHubClient(hubUrl);
        client.RunStarted += (rid, workflowName) => _ = InvokeAsync(() =>
        {
            if (!string.Equals(rid, _activeRunId, StringComparison.OrdinalIgnoreCase))
                return;

            _runStatus = "Running";
            _runStartedAt ??= DateTimeOffset.UtcNow;
            AddRunTimeline("running", "Workflow started", workflowName);
            _logEntries.Add($"[{DateTime.Now:HH:mm:ss}] ▶ Workflow started");
            StateHasChanged();
        });

        client.StepStarted += (rid, step, idx) => _ = InvokeAsync(() =>
        {
            if (!string.Equals(rid, _activeRunId, StringComparison.OrdinalIgnoreCase))
                return;

            _activeStepName = step;
            UpdateStepStatus(step, "Running");
            AddRunTimeline("running", $"Step {idx}: {step}", "Executing");
            _logEntries.Add($"[{DateTime.Now:HH:mm:ss}] ⏳ Step '{step}' started (#{idx})");
            StateHasChanged();
        });

        client.StepCompleted += (rid, step, status, ms, output) => _ = InvokeAsync(() =>
        {
            if (!string.Equals(rid, _activeRunId, StringComparison.OrdinalIgnoreCase))
                return;

            if (string.Equals(_activeStepName, step, StringComparison.OrdinalIgnoreCase))
                _activeStepName = null;

            UpdateStepStatus(step, status);
            AddRunTimeline(
                string.Equals(status, "Failed", StringComparison.OrdinalIgnoreCase) ? "error" : "success",
                $"Step {status}: {step}",
                $"{ms} ms{(string.IsNullOrWhiteSpace(output) ? string.Empty : $" | {TrimForRunEvent(output)}")}");
            _logEntries.Add($"[{DateTime.Now:HH:mm:ss}] {(status.Equals("Failed", StringComparison.OrdinalIgnoreCase) ? "❌" : "✅")} Step '{step}' {status} ({ms}ms)");
            StateHasChanged();
        });

        client.StepFailed += (rid, step, err) => _ = InvokeAsync(() =>
        {
            if (!string.Equals(rid, _activeRunId, StringComparison.OrdinalIgnoreCase))
                return;

            _activeStepName = null;
            UpdateStepStatus(step, "Failed");
            AddRunTimeline("error", $"Step failed: {step}", err);
            _logEntries.Add($"[{DateTime.Now:HH:mm:ss}] ❌ Step '{step}' failed: {err}");
            StateHasChanged();
        });

        client.RunCompleted += (rid, status, totalMs) => _ = InvokeAsync(async () =>
        {
            if (!string.Equals(rid, _activeRunId, StringComparison.OrdinalIgnoreCase))
                return;

            _runCompletedAt = DateTimeOffset.UtcNow;
            _runElapsed = TimeSpan.FromMilliseconds(totalMs);
            await HandleRunStatusChangedAsync(status, emitTimeline: true);
        });

        client.RunFailed += (rid, err) => _ = InvokeAsync(async () =>
        {
            if (!string.Equals(rid, _activeRunId, StringComparison.OrdinalIgnoreCase))
                return;

            _runErrorMessage = err;
            await HandleRunStatusChangedAsync("Failed", error: err, emitTimeline: true);
        });

        client.LogMessage += (rid, level, msg, ts) => _ = InvokeAsync(() =>
        {
            if (!string.Equals(rid, _activeRunId, StringComparison.OrdinalIgnoreCase))
                return;

            _logEntries.Add($"[{ts.ToLocalTime():HH:mm:ss}] [{level}] {msg}");
            StateHasChanged();
        });

        return client;
    }

    private void StartRunElapsedTicker()
    {
        _runTickerCts?.Cancel();
        _runTickerCts?.Dispose();

        _runTickerCts = new CancellationTokenSource();
        var tickerToken = _runTickerCts.Token;

        _ = Task.Run(async () =>
        {
            try
            {
                while (!tickerToken.IsCancellationRequested)
                {
                    await Task.Delay(1000, tickerToken);
                    await InvokeAsync(() =>
                    {
                        if (_runStartedAt is null)
                            return;

                        var end = _runCompletedAt ?? DateTimeOffset.UtcNow;
                        _runElapsed = end - _runStartedAt.Value;
                        StateHasChanged();
                    });
                }
            }
            catch (OperationCanceledException) { }
        }, tickerToken);
    }

    private void StartRunPolling(string runId)
    {
        _runPollingCts?.Cancel();
        _runPollingCts?.Dispose();
        _runPollingCts = new CancellationTokenSource();

        _ = PollRunUpdatesAsync(runId, _runPollingCts.Token);
    }

    private async Task PollRunUpdatesAsync(string runId, CancellationToken ct)
    {
        try
        {
            while (!ct.IsCancellationRequested)
            {
                await Task.Delay(1300, ct);
                var run = await Api.GetRunAsync(runId, ct);
                if (run is null)
                    continue;

                _latestRunSummary = run;
                if (!string.IsNullOrWhiteSpace(run.Error))
                    _runErrorMessage = run.Error;
                if (run.CompletedAt.HasValue)
                    _runCompletedAt = run.CompletedAt.Value;

                if (run.StepResults is { Count: > 0 })
                {
                    foreach (var (key, value) in run.StepResults)
                        TryApplyPolledStepStatus(key, value);
                }

                if (!string.Equals(run.Status, _runStatus, StringComparison.OrdinalIgnoreCase))
                    await HandleRunStatusChangedAsync(run.Status, run.Error, emitTimeline: true);

                await InvokeAsync(StateHasChanged);

                if (run.Status is "Completed" or "Failed" or "Cancelled")
                    break;
            }
        }
        catch (OperationCanceledException) { }
        catch (Exception ex)
        {
            _logEntries.Add($"[{DateTime.Now:HH:mm:ss}] Polling error: {ex.Message}");
        }
    }

    private void TryApplyPolledStepStatus(string key, string value)
    {
        if (key.EndsWith(".Status", StringComparison.OrdinalIgnoreCase))
        {
            var stepName = key[..^".Status".Length];
            if (!_stepStatuses.TryGetValue(stepName, out var previous) ||
                !string.Equals(previous, value, StringComparison.OrdinalIgnoreCase))
            {
                UpdateStepStatus(stepName, value);
                AddRunTimeline("info", $"Status update: {stepName}", value);
            }
            return;
        }

        if (key.EndsWith(".Error", StringComparison.OrdinalIgnoreCase))
        {
            var stepName = key[..^".Error".Length];
            if (!_stepStatuses.TryGetValue(stepName, out var previous) ||
                !string.Equals(previous, "Failed", StringComparison.OrdinalIgnoreCase))
            {
                UpdateStepStatus(stepName, "Failed");
                AddRunTimeline("error", $"Step error: {stepName}", value);
            }
        }
    }

    private void UpdateStepStatus(string stepName, string status)
    {
        if (string.IsNullOrWhiteSpace(stepName))
            return;

        _stepStatuses[stepName] = status;
        _ = HandleStepStatusChanged((stepName, status));
    }

    private async Task HandleRunStatusChangedAsync(string status, string? error = null, bool emitTimeline = false)
    {
        _runStatus = string.IsNullOrWhiteSpace(status) ? "Unknown" : status;
        if (!string.IsNullOrWhiteSpace(error))
            _runErrorMessage = error;

        _logEntries.Add($"[{DateTime.Now:HH:mm:ss}] Run status: {_runStatus}");

        if (emitTimeline)
            AddRunTimeline(GetTimelineKindForStatus(_runStatus), $"Run {_runStatus}", error);

        if (_runStatus is "Completed" or "Failed" or "Cancelled")
        {
            _runCompletedAt ??= DateTimeOffset.UtcNow;
            if (_runStartedAt is not null)
                _runElapsed = _runCompletedAt.Value - _runStartedAt.Value;

            _activeRunId = null;
            _activeStepName = null;
            await StopRunLiveChannelsAsync();
        }

        await InvokeAsync(StateHasChanged);
    }

    private void AddRunTimeline(string kind, string title, string? detail = null)
    {
        _runTimeline.Insert(0, new RunTimelineEntry
        {
            Timestamp = DateTimeOffset.UtcNow,
            Kind = kind,
            Title = title,
            Detail = detail
        });

        if (_runTimeline.Count > 220)
            _runTimeline.RemoveAt(_runTimeline.Count - 1);
    }

    private async Task StopRunLiveChannelsAsync()
    {
        _runPollingCts?.Cancel();
        _runPollingCts?.Dispose();
        _runPollingCts = null;

        _runTickerCts?.Cancel();
        _runTickerCts?.Dispose();
        _runTickerCts = null;

        if (_executionHubClient is not null)
        {
            if (!string.IsNullOrWhiteSpace(_subscribedRunId))
            {
                try { await _executionHubClient.UnsubscribeFromRunAsync(_subscribedRunId); } catch { }
            }

            try { await _executionHubClient.DisposeAsync(); } catch { }
            _executionHubClient = null;
        }

        _subscribedRunId = null;
        _runHubConnected = false;
    }

    private async Task StopRunTrackingAsync(bool clearHistory = false)
    {
        await StopRunLiveChannelsAsync();

        if (!clearHistory)
            return;

        _runStatus = "Idle";
        _runStartedAt = null;
        _runCompletedAt = null;
        _runElapsed = TimeSpan.Zero;
        _activeStepName = null;
        _runErrorMessage = null;
        _latestRunSummary = null;
        _activeRunId = null;
        _stepStatuses.Clear();
        _runTimeline.Clear();
    }

    private static List<RunAssistantTask> BuildRunAssistantTasks(WorkflowDefinitionDto definition)
    {
        static bool ContainsAny(string text, params string[] tokens)
            => tokens.Any(token => text.Contains(token, StringComparison.OrdinalIgnoreCase));

        var tasks = new List<RunAssistantTask>();
        var steps = FlattenSteps(definition.Steps).ToList();
        var workflowHint = definition.Name ?? string.Empty;
        var workflowLooksVoice = ContainsAny(workflowHint, "voice", "audio", "interview", "transcrib", "meeting", "podcast", "brain");

        bool hasVoiceIndicators = false;
        bool hasRecordTask = false;
        bool hasTranscribeTask = false;
        bool addedQuestionsTask = false;
        bool addedQaTask = false;

        foreach (var step in steps)
        {
            var stepName = step.Name ?? "Step";
            var name = stepName.ToLowerInvariant();
            var type = (step.Type ?? string.Empty).ToLowerInvariant();
            var configHint = step.Config is { Count: > 0 }
                ? string.Join(" ", step.Config.SelectMany(kvp => new[] { kvp.Key, kvp.Value }))
                : string.Empty;
            var stepHint = $"{name} {type} {configHint}";
            var isReviewStep = type is "humantaskstep" or "approvalstep"
                || ContainsAny(stepHint, "review", "approval", "human task", "manual");
            var isQuestionStep = ContainsAny(stepHint, "question", "interview")
                || (ContainsAny(stepHint, "prompt")
                    && !ContainsAny(type, "llmcallstep", "agentdecisionstep", "agentplanstep", "agentloopstep"));
            var isQaAnswerStep = ContainsAny(stepHint, "recordanswers", "q/a", "qa pair", "question answer", "interview answer")
                || (ContainsAny(stepHint, "answer", "response") && ContainsAny(stepHint, "interview", "question"));
            var isRecordStep = ContainsAny(stepHint, "record", "capture", "microphone", "mic", "dictat", "voice input", "audio");
            var isTranscribeStep = ContainsAny(stepHint, "transcrib", "speech to text", "speech-to-text", "stt", "whisper");

            if (isRecordStep)
                hasRecordTask = true;
            if (isTranscribeStep)
                hasTranscribeTask = true;

            if (isReviewStep)
            {
                hasVoiceIndicators = true;
                tasks.Add(new RunAssistantTask(stepName, RunAssistantTaskKind.Review, $"Review: {stepName}", "Capture human review notes or approval before execution."));
                continue;
            }

            if (isQaAnswerStep)
            {
                hasVoiceIndicators = true;
                if (!addedQaTask)
                {
                    tasks.Add(new RunAssistantTask(stepName, RunAssistantTaskKind.QaAnswers, "Record/Fill Answers", "Capture answers for generated interview questions."));
                    addedQaTask = true;
                }
                continue;
            }

            if (isQuestionStep)
            {
                hasVoiceIndicators = true;
                if (!addedQuestionsTask)
                {
                    tasks.Add(new RunAssistantTask(stepName, RunAssistantTaskKind.Questions, "Question Planning", "Generate or edit interview questions for this run."));
                    addedQuestionsTask = true;
                }
                continue;
            }

            if (isRecordStep)
            {
                hasVoiceIndicators = true;
                tasks.Add(new RunAssistantTask(stepName, RunAssistantTaskKind.Record, $"Capture Audio: {stepName}", "Record or upload audio for this step."));
                continue;
            }

            if (isTranscribeStep)
            {
                hasVoiceIndicators = true;
                tasks.Add(new RunAssistantTask(stepName, RunAssistantTaskKind.Transcript, $"Transcript Input: {stepName}", "Review or provide transcript text used for this run."));
                continue;
            }
        }

        if (!hasVoiceIndicators && !workflowLooksVoice)
            return [];

        if (!hasRecordTask && hasTranscribeTask)
        {
            tasks.Insert(0, new RunAssistantTask("CaptureAudio", RunAssistantTaskKind.Record, "Capture Audio", "This workflow transcribes audio. Record or upload audio input."));
        }
        else if (tasks.Count == 0 && workflowLooksVoice)
        {
            tasks.Add(new RunAssistantTask("CaptureAudio", RunAssistantTaskKind.Record, "Capture Audio", "Record or upload audio to drive this workflow run."));
            tasks.Add(new RunAssistantTask("Transcript", RunAssistantTaskKind.Transcript, "Transcript Input", "Review transcript text that should be sent with this run."));
        }

        return tasks;
    }

    private static IEnumerable<StepDefinitionApiDto> FlattenSteps(IEnumerable<StepDefinitionApiDto> steps)
    {
        foreach (var step in steps)
        {
            yield return step;

            if (step.Steps is { Count: > 0 })
            {
                foreach (var child in FlattenSteps(step.Steps))
                    yield return child;
            }

            if (step.Inner is not null)
            {
                foreach (var child in FlattenSteps([step.Inner]))
                    yield return child;
            }

            if (step.Then is not null)
            {
                foreach (var child in FlattenSteps([step.Then]))
                    yield return child;
            }

            if (step.Else is not null)
            {
                foreach (var child in FlattenSteps([step.Else]))
                    yield return child;
            }

            if (step.TryBody is { Count: > 0 })
            {
                foreach (var child in FlattenSteps(step.TryBody))
                    yield return child;
            }

            if (step.FinallyBody is { Count: > 0 })
            {
                foreach (var child in FlattenSteps(step.FinallyBody))
                    yield return child;
            }
        }
    }

    private void InitializeRunAssistant(List<RunAssistantTask> tasks)
    {
        _runAssistantTasks.Clear();
        _runAssistantTasks.AddRange(tasks);
        _runAssistantIndex = 0;
        _runAssistantActive = true;
        _runTranscript = "";
        _runLiveFinalTranscript = "";
        _runLiveInterimTranscript = "";
        _runAudioByStep.Clear();
        _runReviews.Clear();
        _runQuestions.Clear();
        _runQaPairs.Clear();
    }

    private async Task CancelRunAssistant()
    {
        _runAssistantActive = false;
        _runAssistantTasks.Clear();
        _runAssistantIndex = 0;
        _runQuestions.Clear();
        _runQaPairs.Clear();
        _runReviews.Clear();
        _runAudioByStep.Clear();
        _runTranscript = "";
        _runLiveFinalTranscript = "";
        _runLiveInterimTranscript = "";
        _runBusy = false;

        if (_runRecording)
        {
            _runRecording = false;
            try { await JS.InvokeVoidAsync("voiceRecorder.stopRecording"); } catch { }
        }

        try { await JS.InvokeVoidAsync("voiceRecorder.clearPreview"); } catch { }
    }

    private void JumpToRunTask(int index)
    {
        if (!_runAssistantActive || index < 0 || index >= _runAssistantTasks.Count)
            return;

        var canJumpForward = index <= _runAssistantIndex
            || _runAssistantTasks.Take(index).All(IsRunTaskSatisfied);

        if (canJumpForward)
            _runAssistantIndex = index;
    }

    private void GoToPreviousRunTask()
    {
        if (_runAssistantIndex > 0)
            _runAssistantIndex--;
    }

    private void GoToNextRunTask()
    {
        var task = CurrentRunTask;
        if (task is null || !CanAdvanceRunTask(task))
            return;

        if (_runAssistantIndex < _runAssistantTasks.Count - 1)
            _runAssistantIndex++;
    }

    private bool IsRunTaskSatisfied(RunAssistantTask task)
        => CanAdvanceRunTask(task);

    private bool CanAdvanceRunTask(RunAssistantTask task) => task.Kind switch
    {
        RunAssistantTaskKind.Record => _runAudioByStep.ContainsKey(task.StepName) || !string.IsNullOrWhiteSpace(_runTranscript),
        RunAssistantTaskKind.Transcript => !string.IsNullOrWhiteSpace(_runTranscript),
        RunAssistantTaskKind.Review => !string.IsNullOrWhiteSpace(GetRunReviewText(task.StepName)),
        RunAssistantTaskKind.Questions => _runQuestions.Any(q => !string.IsNullOrWhiteSpace(q)),
        RunAssistantTaskKind.QaAnswers => _runQaPairs.Count > 0 && _runQaPairs.All(q => !string.IsNullOrWhiteSpace(q.Question) && !string.IsNullOrWhiteSpace(q.Answer)),
        _ => true
    };

    private bool CanStartRunAssistant()
        => _runAssistantTasks.All(IsRunTaskSatisfied);

    private async Task RunWithAssistantInputsAsync()
    {
        if (_runBusy || !CanStartRunAssistant())
            return;

        var request = BuildRunAssistantRequest();
        await StartWorkflowRunAsync(request);
        await CancelRunAssistant();
    }

    private StartRunRequestDto BuildRunAssistantRequest()
    {
        var qaPairs = _runQaPairs
            .Where(q => !string.IsNullOrWhiteSpace(q.Question) || !string.IsNullOrWhiteSpace(q.Answer))
            .Select(q => new Dictionary<string, object?>
            {
                ["question"] = q.Question.Trim(),
                ["answer"] = q.Answer.Trim()
            })
            .ToList();

        var recordings = _runAudioByStep.ToDictionary(
            kvp => kvp.Key,
            kvp => (object?)new Dictionary<string, object?>
            {
                ["fileName"] = kvp.Value.FileName,
                ["mimeType"] = kvp.Value.MimeType,
                ["size"] = kvp.Value.Size,
                ["base64"] = kvp.Value.Base64
            },
            StringComparer.OrdinalIgnoreCase);

        var reviews = _runReviews
            .Where(kvp => !string.IsNullOrWhiteSpace(kvp.Value))
            .ToDictionary(kvp => kvp.Key, kvp => kvp.Value, StringComparer.OrdinalIgnoreCase);

        var requestInputs = new Dictionary<string, object?>
        {
            ["transcript"] = _runTranscript.Trim(),
            ["questions"] = _runQuestions.Where(q => !string.IsNullOrWhiteSpace(q)).ToList(),
            ["qaPairs"] = qaPairs,
            ["reviews"] = reviews,
            ["recordings"] = recordings
        };

        return new StartRunRequestDto
        {
            Source = "designer-run-assistant",
            Inputs = requestInputs
        };
    }

    private async Task ToggleRunRecordingAsync()
    {
        if (_runBusy)
            return;

        if (_runRecording)
        {
            await StopRunRecordingAsync();
            return;
        }

        if (!_runRecorderSupported || _dotNetRef is null)
            return;

        try
        {
            _runBusy = true;
            var startResult = await JS.InvokeAsync<RecordingStartResult>("voiceRecorder.startRecording", _runSelectedDeviceId, _dotNetRef);
            _runSpeechRecognitionSupported = startResult.SpeechRecognition;
            _runRecording = startResult.IsRecording;
            if (!_runRecording)
            {
                Toast.Warning("Recorder did not start. Verify browser microphone permissions.");
            }
        }
        catch (Exception ex)
        {
            if (ex.Message.Contains("not supported", StringComparison.OrdinalIgnoreCase))
                _runRecorderSupported = false;
            Toast.Error($"Unable to start recording: {ex.Message}");
        }
        finally
        {
            _runBusy = false;
        }
    }

    private async Task StopRunRecordingAsync()
    {
        var task = CurrentRunTask;
        if (task is null)
            return;

        try
        {
            _runBusy = true;
            var payload = await JS.InvokeAsync<BrowserAudioPayload?>("voiceRecorder.stopRecording");
            _runRecording = false;
            if (payload is not null)
            {
                _runAudioByStep[task.StepName] = payload;
                if (!string.IsNullOrWhiteSpace(payload.LiveTranscript))
                    _runTranscript = payload.LiveTranscript;
            }
        }
        catch (Exception ex)
        {
            Toast.Error($"Unable to stop recording: {ex.Message}");
        }
        finally
        {
            _runBusy = false;
        }
    }

    private async Task HandleRunAudioUploadAsync(InputFileChangeEventArgs e)
    {
        var task = CurrentRunTask;
        var file = e.File;
        if (task is null || file is null)
            return;

        try
        {
            _runBusy = true;
            await using var stream = file.OpenReadStream(maxAllowedSize: 1024L * 1024L * 30L);
            await using var ms = new MemoryStream();
            await stream.CopyToAsync(ms);
            var base64 = Convert.ToBase64String(ms.ToArray());

            _runAudioByStep[task.StepName] = new BrowserAudioPayload
            {
                FileName = file.Name,
                MimeType = file.ContentType ?? "audio/wav",
                Size = ms.Length,
                Base64 = base64,
                PreviewUrl = $"data:{file.ContentType};base64,{base64}",
                LiveTranscript = _runTranscript
            };
        }
        catch (Exception ex)
        {
            Toast.Error($"Audio upload failed: {ex.Message}");
        }
        finally
        {
            _runBusy = false;
        }
    }

    private string GetRunReviewText(string stepName)
    {
        return _runReviews.TryGetValue(stepName, out var text) ? text : "";
    }

    private void SetRunReviewText(string stepName, string value)
    {
        _runReviews[stepName] = value;
    }

    private void GenerateRunQuestions()
    {
        if (string.IsNullOrWhiteSpace(_runTranscript))
            return;

        var generated = Regex.Matches(_runTranscript, @"([^?.!\n]{8,}\?)")
            .Cast<Match>()
            .Select(m => m.Value.Trim())
            .Where(q => q.Length >= 12)
            .Distinct(StringComparer.OrdinalIgnoreCase)
            .Take(6)
            .ToList();

        if (generated.Count == 0)
        {
            generated = Regex.Split(_runTranscript, @"(?<=[.!])\s+")
                .Select(s => s.Trim())
                .Where(s => s.Length > 24)
                .Take(4)
                .Select(s => $"Can you expand on: {TrimForQuestion(s)}?")
                .ToList();
        }

        if (generated.Count == 0)
            return;

        _runQuestions.Clear();
        _runQuestions.AddRange(generated);
        SyncQaPairsFromQuestions();
    }

    private void AddRunQuestion()
    {
        _runQuestions.Add("New question");
        SyncQaPairsFromQuestions();
    }

    private void SetRunQuestion(int index, string value)
    {
        if (index < 0 || index >= _runQuestions.Count)
            return;

        _runQuestions[index] = value;
        SyncQaPairsFromQuestions();
    }

    private void RemoveRunQuestion(int index)
    {
        if (index < 0 || index >= _runQuestions.Count)
            return;

        _runQuestions.RemoveAt(index);
        SyncQaPairsFromQuestions();
    }

    private void SyncQaPairsFromQuestions()
    {
        var currentAnswers = _runQaPairs
            .Where(q => !string.IsNullOrWhiteSpace(q.Question))
            .ToDictionary(q => q.Question, q => q.Answer, StringComparer.OrdinalIgnoreCase);

        _runQaPairs.Clear();
        foreach (var question in _runQuestions.Where(q => !string.IsNullOrWhiteSpace(q)))
        {
            currentAnswers.TryGetValue(question, out var answer);
            _runQaPairs.Add(new RunQaPair { Question = question, Answer = answer ?? string.Empty });
        }
    }

    private void SetRunQaQuestion(int index, string value)
    {
        if (index < 0 || index >= _runQaPairs.Count)
            return;

        _runQaPairs[index].Question = value;
        if (index < _runQuestions.Count)
            _runQuestions[index] = value;
    }

    private void SetRunQaAnswer(int index, string value)
    {
        if (index < 0 || index >= _runQaPairs.Count)
            return;

        _runQaPairs[index].Answer = value;
    }

    private static string TrimForQuestion(string sentence)
    {
        const int max = 72;
        return sentence.Length <= max ? sentence : $"{sentence[..max].TrimEnd()}...";
    }

    private static string FormatFileSize(long bytes)
    {
        if (bytes <= 0) return "0 B";
        string[] suffixes = ["B", "KB", "MB", "GB"];
        var idx = 0;
        double value = bytes;
        while (value >= 1024 && idx < suffixes.Length - 1)
        {
            value /= 1024;
            idx++;
        }
        return $"{value:0.#} {suffixes[idx]}";
    }

    private async Task HandleExportJson()
    {
        try
        {
            if (_currentWorkflowId is not null)
            {
                var export = await Api.ExportWorkflowAsync(_currentWorkflowId);
                if (export is not null)
                {
                    await JS.InvokeVoidAsync("downloadJson", $"{_workflowName}.json", export);
                    _logEntries.Add($"[{DateTime.Now:HH:mm:ss}] Exported workflow as JSON file");
                    Toast.Success("Exported as JSON");
                    return;
                }
            }
            // Fallback: copy canvas data to clipboard
            var definition = await JS.InvokeAsync<object>("workflowEditor.getWorkflowDefinition");
            var json = System.Text.Json.JsonSerializer.Serialize(definition, new System.Text.Json.JsonSerializerOptions { WriteIndented = true });
            await JS.InvokeVoidAsync("navigator.clipboard.writeText", json);
            _logEntries.Add($"[{DateTime.Now:HH:mm:ss}] JSON copied to clipboard (save workflow first for full export)");
        }
        catch (Exception ex)
        {
            _logEntries.Add($"[{DateTime.Now:HH:mm:ss}] Export failed: {ex.Message}");
            Toast.Error($"Export failed: {ex.Message}");
        }
    }

    private async Task HandleExportYaml()
    {
