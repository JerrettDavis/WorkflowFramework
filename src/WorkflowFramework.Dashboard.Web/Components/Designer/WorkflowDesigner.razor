    /// <summary>
    /// Reconstructs a WorkflowDefinitionDto from the flat nodes/edges returned by JS getWorkflowDefinition().
    /// </summary>
    private WorkflowDefinitionDto CanvasToDefinition(System.Text.Json.JsonElement canvasData)
    {
        static bool IsUnlabeledEdge(CanvasEdge edge) => string.IsNullOrWhiteSpace(edge.Label);

        var dto = new WorkflowDefinitionDto { Name = _workflowName };

        var (nodes, edges) = ParseCanvasGraph(canvasData);
        dto.Canvas = CreateCanvasSnapshot(nodes, edges);

        if (nodes.Count == 0)
            return dto;

        var nodeMap = nodes.ToDictionary(n => n.Id);
        var outEdges = edges.GroupBy(e => e.Source).ToDictionary(g => g.Key, g => g.ToList());
        var inEdges = edges.GroupBy(e => e.Target).ToDictionary(g => g.Key, g => g.ToList());

        // Synthetic merge/join nodes (generated by LoadDefinitionIntoCanvas) should be skipped
        bool IsSynthetic(CanvasNode n)
            => string.Equals(n.Config.GetValueOrDefault("__syntheticKind"), "container-exit", StringComparison.Ordinal);

        var nodeOrder = nodes
            .Select((node, index) => new { node.Id, index })
            .ToDictionary(x => x.Id, x => x.index, StringComparer.Ordinal);

        // Find root nodes: no incoming edges and not synthetic
        var roots = nodes.Where(n => !IsSynthetic(n) && !inEdges.ContainsKey(n.Id)).ToList();

        // Prefer the original canvas node order before falling back to numeric suffixes for imported ids.
        roots.Sort((a, b) =>
        {
            var orderCompare = nodeOrder[a.Id].CompareTo(nodeOrder[b.Id]);
            return orderCompare != 0 ? orderCompare : GetNodeOrderKey(a.Id).CompareTo(GetNodeOrderKey(b.Id));
        });

        static int GetNodeOrderKey(string id)
        {
            var separatorIndex = id.LastIndexOf('_');
            return separatorIndex >= 0
                && separatorIndex < id.Length - 1
                && int.TryParse(id[(separatorIndex + 1)..], out var numericSuffix)
                    ? numericSuffix
                    : int.MaxValue;
        }

        var visited = new HashSet<string>();

        static string NormalizeType(string? type) => type?.Trim().ToLowerInvariant() ?? string.Empty;

        bool IsContainer(CanvasNode node)
            => NormalizeType(node.Type) is "conditional" or "parallel" or "retry" or "foreach" or "while" or "dowhile" or "saga" or "trycatch" or "timeout";

        string? GetContainerExitId(string ownerId)
            => nodes.FirstOrDefault(n =>
                IsSynthetic(n)
                && string.Equals(n.Config.GetValueOrDefault("__syntheticKind"), "container-exit", StringComparison.Ordinal)
                && string.Equals(n.Config.GetValueOrDefault("__ownerId"), ownerId, StringComparison.Ordinal))?.Id;

        CanvasEdge? GetContinueEdge(string nodeId)
            => (outEdges.GetValueOrDefault(nodeId) ?? [])
                .FirstOrDefault(e => string.Equals(e.Kind, "continue", StringComparison.OrdinalIgnoreCase));

        string? GetSequentialNextId(string nodeId, string? stopAtExitId = null)
        {
            if (!nodeMap.TryGetValue(nodeId, out var currentNode))
                return null;

            if (IsContainer(currentNode))
            {
                var exitId = GetContainerExitId(nodeId);
                if (string.IsNullOrWhiteSpace(exitId))
                {
                    var continueEdge = GetContinueEdge(nodeId);
                    if (continueEdge is null || string.Equals(continueEdge.Target, stopAtExitId, StringComparison.Ordinal))
                        return null;

                    return nodeMap.TryGetValue(continueEdge.Target, out var continuationNode) && !IsSynthetic(continuationNode)
                        ? continueEdge.Target
                        : null;
                }

                if (string.Equals(exitId, stopAtExitId, StringComparison.Ordinal))
                    return null;

                var exitOuts = outEdges.GetValueOrDefault(exitId);
                var nextEdge = exitOuts?.FirstOrDefault(IsUnlabeledEdge);
                if (nextEdge is null || string.Equals(nextEdge.Target, stopAtExitId, StringComparison.Ordinal))
                    return null;

                return nodeMap.TryGetValue(nextEdge.Target, out var exitTargetNode) && !IsSynthetic(exitTargetNode)
                    ? nextEdge.Target
                    : null;
            }

            var outs = outEdges.GetValueOrDefault(nodeId);
            var seqEdge = outs?.FirstOrDefault(IsUnlabeledEdge);
            if (seqEdge is null || string.Equals(seqEdge.Target, stopAtExitId, StringComparison.Ordinal))
                return null;

            return nodeMap.TryGetValue(seqEdge.Target, out var targetNode) && !IsSynthetic(targetNode)
                ? seqEdge.Target
                : null;
        }

        List<StepDefinitionApiDto>? BuildSequenceFrom(string? startId, string? stopAtExitId = null)
        {
            var steps = new List<StepDefinitionApiDto>();
            while (!string.IsNullOrWhiteSpace(startId) && !string.Equals(startId, stopAtExitId, StringComparison.Ordinal))
            {
                if (!nodeMap.TryGetValue(startId, out var currentNode) || IsSynthetic(currentNode))
                    break;

                var step = BuildStep(startId);
                if (step is null)
                    break;

                steps.Add(step);
                startId = GetSequentialNextId(startId, stopAtExitId);
            }

            return steps.Count > 0 ? steps : null;
        }

        StepDefinitionApiDto? BuildStep(string nodeId)
        {
            if (!visited.Add(nodeId)) return null;
            if (!nodeMap.TryGetValue(nodeId, out var node)) return null;
            if (IsSynthetic(node)) return null;

            var stepConfig = node.Config.Count > 0 ? new Dictionary<string, string>(node.Config) : null;
            if (stepConfig is not null)
            {
                stepConfig.Remove("label");
                stepConfig.Remove("_notes");
                foreach (var designerKey in stepConfig.Keys.Where(static key => key.StartsWith("__", StringComparison.Ordinal)).ToList())
                    stepConfig.Remove(designerKey);
                if (stepConfig.Count == 0)
                    stepConfig = null;
            }

            var step = new StepDefinitionApiDto
            {
                Name = node.Label,
                Type = node.Type,
                Config = stepConfig
            };
            var normalizedType = NormalizeType(node.Type);

            // Extract well-known properties from config into DTO fields
            if (step.Config is not null)
            {
                if (step.Config.TryGetValue("maxAttempts", out var ma) && int.TryParse(ma, out var maxAtt))
                {
                    step.MaxAttempts = maxAtt;
                    step.Config.Remove("maxAttempts");
                }
                if (step.Config.TryGetValue("timeoutSeconds", out var ts) && double.TryParse(ts, NumberStyles.Float, CultureInfo.InvariantCulture, out var timeout))
                {
                    step.TimeoutSeconds = timeout;
                    step.Config.Remove("timeoutSeconds");
                }
                if (step.Config.TryGetValue("delaySeconds", out var ds) && double.TryParse(ds, NumberStyles.Float, CultureInfo.InvariantCulture, out var delay))
                {
                    step.DelaySeconds = delay;
                    step.Config.Remove("delaySeconds");
                }
                if (step.Config.TryGetValue("catchTypes", out var ct) && !string.IsNullOrWhiteSpace(ct))
                {
                    step.CatchTypes = ct.Split(',', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries).ToList();
                    step.Config.Remove("catchTypes");
                }
                if (step.Config.TryGetValue("subWorkflowName", out var subWorkflowName) && !string.IsNullOrWhiteSpace(subWorkflowName))
                {
                    step.SubWorkflowName = subWorkflowName;
                    step.Config.Remove("subWorkflowName");
                }
                if (step.Config.Count == 0) step.Config = null;
            }

            var outs = outEdges.GetValueOrDefault(node.Id) ?? [];

            if (normalizedType == "conditional")
            {
                var thenEdge = outs.FirstOrDefault(e => string.Equals(e.Kind, "then", StringComparison.OrdinalIgnoreCase) || string.Equals(e.Label, "then", StringComparison.OrdinalIgnoreCase));
                var elseEdge = outs.FirstOrDefault(e => string.Equals(e.Kind, "else", StringComparison.OrdinalIgnoreCase) || string.Equals(e.Label, "else", StringComparison.OrdinalIgnoreCase));

                if (thenEdge is not null)
                    step.Then = BuildStep(thenEdge.Target) ?? BuildChainFrom(thenEdge.Target);
                if (elseEdge is not null)
                    step.Else = BuildStep(elseEdge.Target) ?? BuildChainFrom(elseEdge.Target);

                return step;
            }

            if (normalizedType == "parallel")
            {
                step.Steps = [];
                foreach (var edge in outs
                    .Where(e => !string.Equals(e.Kind, "continue", StringComparison.OrdinalIgnoreCase))
                    .OrderBy(e => GetParallelBranchOrder(e.Kind))
                    .ThenBy(e => e.Id, StringComparer.Ordinal))
                {
                    var child = BuildStep(edge.Target);
                    if (child is not null) step.Steps.Add(child);
                }
                if (step.Steps.Count == 0) step.Steps = null;
                return step;
            }

            static int GetParallelBranchOrder(string? kind)
            {
                const string prefix = "output-";
                return kind is not null
                    && kind.StartsWith(prefix, StringComparison.OrdinalIgnoreCase)
                    && int.TryParse(kind[prefix.Length..], out var branchIndex)
                        ? branchIndex
                        : int.MaxValue;
            }

            if (normalizedType is "retry" or "foreach" or "while" or "dowhile" or "saga"
                && outs.Count > 0)
            {
                var continueEdge = GetContinueEdge(node.Id);
                var stopAtId = continueEdge?.Target ?? GetContainerExitId(node.Id);
                var bodyEdge = outs.FirstOrDefault(e => string.Equals(e.Kind, "body", StringComparison.OrdinalIgnoreCase))
                    ?? outs.FirstOrDefault(e => !string.Equals(e.Kind, "continue", StringComparison.OrdinalIgnoreCase));
                step.Steps = bodyEdge is null ? null : BuildSequenceFrom(bodyEdge.Target, stopAtId);
                return step;
            }

            if (normalizedType == "timeout")
            {
                var innerEdge = outs.FirstOrDefault(e => string.Equals(e.Kind, "inner", StringComparison.OrdinalIgnoreCase))
                    ?? outs.FirstOrDefault(e => !string.Equals(e.Kind, "continue", StringComparison.OrdinalIgnoreCase));
                if (innerEdge is not null)
                    step.Inner = BuildStep(innerEdge.Target) ?? BuildChainFrom(innerEdge.Target);
                return step;
            }

            if (normalizedType == "trycatch" && outs.Count > 0)
            {
                step.TryBody = [];
                var continueEdge = GetContinueEdge(node.Id);
                var stopAtId = continueEdge?.Target ?? GetContainerExitId(node.Id);
                var nodeFinallyEdge = outs.FirstOrDefault(e => string.Equals(e.Kind, "finally", StringComparison.OrdinalIgnoreCase));
                var tryEdge = outs.FirstOrDefault(e => string.Equals(e.Kind, "try", StringComparison.OrdinalIgnoreCase))
                    ?? outs.FirstOrDefault(e => !string.Equals(e.Kind, "continue", StringComparison.OrdinalIgnoreCase));
                if (tryEdge is null)
                {
                    if (nodeFinallyEdge is not null)
                        step.FinallyBody = BuildSequenceFrom(nodeFinallyEdge.Target, stopAtId);
                    return step;
                }
                var childId = tryEdge.Target;
                while (childId is not null)
                {
                    var child = BuildStep(childId);
                    if (child is null) break;
                    step.TryBody.Add(child);

                    var childOuts = outEdges.GetValueOrDefault(childId) ?? [];
                    var finallyEdge = childOuts.FirstOrDefault(e => string.Equals(e.Kind, "finally", StringComparison.OrdinalIgnoreCase));
                    if (finallyEdge is not null)
                    {
                        step.FinallyBody = BuildSequenceFrom(finallyEdge.Target, stopAtId);
                        childId = null;
                    }
                    else
                    {
                        childId = GetSequentialNextId(childId, stopAtId);
                    }
                }

                if (step.FinallyBody is null && nodeFinallyEdge is not null)
                    step.FinallyBody = BuildSequenceFrom(nodeFinallyEdge.Target, stopAtId);

                if (step.TryBody.Count == 0) step.TryBody = null;
                return step;
            }

            return step;
        }

        // Build a chain following sequential edges from a node (skipping synthetic nodes)
        StepDefinitionApiDto? BuildChainFrom(string nodeId)
        {
            return BuildStep(nodeId);
        }

        // Walk roots and their sequential successors
        foreach (var root in roots)
        {
            var steps = BuildSequenceFrom(root.Id);
            if (steps is not null)
                dto.Steps.AddRange(steps);
        }

        return dto;
    }

