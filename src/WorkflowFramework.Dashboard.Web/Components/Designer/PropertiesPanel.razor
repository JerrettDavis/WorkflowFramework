@inject DashboardApiClient Api
@implements IDisposable

<div class="w-80 bg-gray-800 border-l border-gray-700 overflow-y-auto flex-shrink-0" data-testid="properties-panel">
    @if (SelectedNodeId is null)
    {
        <div class="p-4 text-gray-500 text-sm text-center mt-8">
            <p class="text-2xl mb-2">🔧</p>
            <p>Select a step on the canvas to edit its properties</p>
        </div>
    }
    else
    {
        var stepDef = _localSteps.FirstOrDefault(s => s.Type == SelectedNodeType);
        var categoryColor = stepDef?.Color ?? StepCatalog.CategoryColors.GetValueOrDefault(stepDef?.Category ?? "", "#6b7280");

        @* Header with icon, name, type badge, category *@
        <div class="p-3 border-b border-gray-700" data-testid="properties-header">
            <div class="flex items-center gap-2 mb-1">
                <span class="text-lg">@(stepDef?.Icon ?? "⬡")</span>
                <span class="text-sm font-semibold text-gray-100 flex-1 truncate">@(NodeConfig.GetValueOrDefault("label")?.ToString() ?? stepDef?.Name ?? SelectedNodeType)</span>
            </div>
            <div class="flex items-center gap-1.5 mt-1">
                <span class="px-1.5 py-0.5 rounded text-[10px] font-medium" style="background: @(categoryColor)22; color: @categoryColor">@(stepDef?.Category ?? "Unknown")</span>
                <span class="px-1.5 py-0.5 rounded bg-gray-700 text-gray-400 text-[10px] font-mono">@SelectedNodeType</span>
            </div>
        </div>

        @* Step type description *@
        @if (_stepTypeDescription is not null)
        {
            <div class="px-3 py-2 border-b border-gray-700 text-xs text-gray-400 italic" data-testid="properties-description">
                @_stepTypeDescription
            </div>
        }

        @if (_loadingSchema)
        {
            <div class="p-3 text-gray-500 text-xs animate-pulse">Loading schema...</div>
        }

        <div class="p-3 space-y-3">
            @* Step Name *@
            <div>
                <label class="block text-xs text-gray-400 mb-1">Step Name</label>
                <input type="text" value="@(NodeConfig.GetValueOrDefault("label")?.ToString() ?? string.Empty)"
                       @oninput='e => UpdateConfig("label", e.Value)'
                       data-testid="properties-step-name"
                       class="w-full bg-gray-700 text-gray-200 text-sm px-2 py-1 rounded focus:outline-none focus:ring-1 focus:ring-blue-500" />
            </div>

            @* Notes/Description *@
            <div>
                <label class="block text-xs text-gray-400 mb-1">Notes</label>
                <textarea rows="2"
                          @oninput='e => UpdateConfig("_notes", e.Value)'
                          data-testid="properties-notes"
                          class="w-full bg-gray-700 text-gray-200 text-sm px-2 py-1 rounded focus:outline-none focus:ring-1 focus:ring-blue-500 resize-y">@(NodeConfig.GetValueOrDefault("_notes")?.ToString() ?? string.Empty)</textarea>
            </div>

            @* Connections *@
            @if (Connections is not null && (Connections.Inputs.Count > 0 || Connections.Outputs.Count > 0))
            {
                <div class="border-t border-gray-700 pt-2" data-testid="properties-connections">
                    <label class="block text-xs text-gray-400 mb-1.5 uppercase tracking-wider font-semibold">Connections</label>
                    @if (Connections.Inputs.Count > 0)
                    {
                        <div class="mb-1.5">
                            <span class="text-[10px] text-gray-500 uppercase">Inputs from:</span>
                            <div class="flex flex-wrap gap-1 mt-0.5">
                                @foreach (var input in Connections.Inputs)
                                {
                                    <button @onclick="() => OnConnectionClicked.InvokeAsync(input.Id)"
                                            class="px-1.5 py-0.5 rounded bg-gray-700 text-gray-300 text-[10px] hover:bg-gray-600 cursor-pointer">
                                        @if (input.EdgeLabel is not null) { <span class="text-gray-500 mr-0.5">@input.EdgeLabel:</span> }
                                        @input.Label
                                    </button>
                                }
                            </div>
                        </div>
                    }
                    @if (Connections.Outputs.Count > 0)
                    {
                        <div>
                            <span class="text-[10px] text-gray-500 uppercase">Outputs to:</span>
                            <div class="flex flex-wrap gap-1 mt-0.5">
                                @foreach (var output in Connections.Outputs)
                                {
                                    <button @onclick="() => OnConnectionClicked.InvokeAsync(output.Id)"
                                            class="px-1.5 py-0.5 rounded bg-gray-700 text-gray-300 text-[10px] hover:bg-gray-600 cursor-pointer">
                                        @if (output.EdgeLabel is not null) { <span class="text-gray-500 mr-0.5">@output.EdgeLabel:</span> }
                                        @output.Label
                                    </button>
                                }
                            </div>
                        </div>
                    }
                </div>
            }

            @* Children for container steps *@
            @if (Connections is not null && IsContainerType(SelectedNodeType) && Connections.Outputs.Count > 0)
            {
                <div class="border-t border-gray-700 pt-2" data-testid="properties-children">
                    <label class="block text-xs text-gray-400 mb-1.5 uppercase tracking-wider font-semibold">Child Steps</label>
                    <div class="space-y-0.5">
                        @foreach (var child in Connections.Outputs)
                        {
                            <button @onclick="() => OnConnectionClicked.InvokeAsync(child.Id)"
                                    class="w-full flex items-center gap-1.5 px-2 py-1 rounded text-left hover:bg-gray-700 text-xs">
                                @if (child.EdgeLabel is not null) { <span class="text-gray-500 font-mono text-[10px]">@child.EdgeLabel</span> }
                                <span class="text-gray-200">@child.Label</span>
                            </button>
                        }
                    </div>
                </div>
            }

            @* Schema-driven configuration fields *@
            @if (_schemaFields.Count > 0)
            {
                <div class="border-t border-gray-700 pt-2">
                    <label class="block text-xs text-gray-400 mb-1.5 uppercase tracking-wider font-semibold">Configuration</label>
                    @foreach (var field in _schemaFields)
                    {
                        <div class="mb-3">
                            <label class="block text-xs text-gray-400 mb-1">
                                @field.Label
                                @if (field.Required) { <span class="text-red-400 ml-0.5">*</span> }
                            </label>

                            @switch (field.UiType)
                            {
                                case "providerSelect":
                                    <select value="@GetConfigValue(field)"
                                            @onchange='e => OnProviderChangedAsync(field, e.Value?.ToString())'
                                            class="w-full bg-gray-700 text-gray-200 text-sm px-2 py-1 rounded focus:outline-none focus:ring-1 focus:ring-blue-500">
                                        <option value="">— Select provider —</option>
                                        @foreach (var provider in GetAvailableOptions(field))
                                        {
                                            <option value="@provider">@FormatOptionLabel(provider)</option>
                                        }
                                    </select>
                                    break;

                                 case "modelSelect":
                                     @if (UsesManualModelEntry(field))
                                     {
                                         <input type="text"
                                                list="@GetProviderModelSuggestionListId(field)"
                                                value="@GetConfigValue(field)"
                                                placeholder="@GetModelPlaceholder(field)"
                                                data-testid="properties-model-input-@field.Name"
                                                @oninput='e => UpdateConfig(field.Name, e.Value)'
                                                class="w-full bg-gray-700 text-gray-200 text-sm px-2 py-1 rounded focus:outline-none focus:ring-1 focus:ring-blue-500" />
                                         <datalist id="@GetProviderModelSuggestionListId(field)">
                                             @foreach (var model in GetAvailableOptions(field))
                                             {
                                                 <option value="@model">@model</option>
                                             }
                                         </datalist>
                                     }
                                     else
                                     {
                                         <select value="@GetConfigValue(field)"
                                                 @onchange='e => UpdateConfig(field.Name, e.Value)'
                                                 class="w-full bg-gray-700 text-gray-200 text-sm px-2 py-1 rounded focus:outline-none focus:ring-1 focus:ring-blue-500">
                                             <option value="">@GetModelPlaceholder(field)</option>
                                             @foreach (var model in GetAvailableOptions(field))
                                             {
                                                 <option value="@model">@model</option>
                                             }
                                         </select>
                                     }
                                     break;

                                 case "select":
                                     <select value="@GetConfigValue(field)"
                                             @onchange='e => UpdateConfig(field.Name, e.Value)'
                                             class="w-full bg-gray-700 text-gray-200 text-sm px-2 py-1 rounded focus:outline-none focus:ring-1 focus:ring-blue-500">
                                        <option value="">— Select —</option>
                                        @if (field.Options is not null)
                                        {
                                            @foreach (var opt in field.Options)
                                            {
                                                <option value="@opt">@opt</option>
                                            }
                                        }
                                     </select>
                                     break;

                                 case "workflowSelect":
                                     <input type="text"
                                            list="@GetWorkflowReferenceListId(field)"
                                            value="@GetConfigValue(field)"
                                            placeholder="Start typing or pick a saved workflow"
                                            data-testid="properties-workflow-reference-input-@field.Name"
                                            @oninput='e => UpdateConfig(field.Name, e.Value)'
                                            class="w-full bg-gray-700 text-gray-200 text-sm px-2 py-1 rounded focus:outline-none focus:ring-1 focus:ring-blue-500" />
                                     <datalist id="@GetWorkflowReferenceListId(field)">
                                         @foreach (var workflow in GetWorkflowReferenceSuggestions(field))
                                         {
                                             <option value="@workflow.Name">@GetWorkflowReferenceOptionLabel(workflow)</option>
                                         }
                                     </datalist>
                                     break;

                                 case "textarea":
                                     <textarea rows="@(field.Rows > 0 ? field.Rows : 3)"
                                               placeholder="@(field.Default ?? "")"
                                              @oninput='e => UpdateConfig(field.Name, e.Value)'
                                              class="w-full bg-gray-700 text-gray-200 text-sm px-2 py-1 rounded focus:outline-none focus:ring-1 focus:ring-blue-500 resize-y">@(NodeConfig.GetValueOrDefault(field.Name)?.ToString() ?? string.Empty)</textarea>
                                    break;

                                case "json":
                                    <textarea rows="@(field.Rows > 0 ? field.Rows : 4)"
                                              placeholder="@(field.Default ?? "")"
                                              @oninput='e => UpdateConfig(field.Name, e.Value)'
                                              class="w-full bg-gray-700 text-gray-200 text-sm px-2 py-1 rounded focus:outline-none focus:ring-1 focus:ring-blue-500 resize-y font-mono text-xs">@(NodeConfig.GetValueOrDefault(field.Name)?.ToString() ?? string.Empty)</textarea>
                                    break;

                                case "slider":
                                    <div class="flex items-center gap-2">
                                        <input type="range"
                                               min="@field.Min" max="@field.Max" step="@(field.Step > 0 ? field.Step : 1)"
                                               value="@(NodeConfig.GetValueOrDefault(field.Name)?.ToString() ?? field.Default ?? "0")"
                                               @oninput='e => UpdateConfig(field.Name, e.Value)'
                                               class="flex-1 accent-blue-500" />
                                        <span class="text-xs text-gray-300 w-10 text-right font-mono">@(NodeConfig.GetValueOrDefault(field.Name)?.ToString() ?? field.Default ?? "0")</span>
                                    </div>
                                    break;

                                case "number":
                                    <input type="number"
                                           value="@GetConfigValue(field)"
                                           placeholder="@(field.Default ?? "")"
                                           min="@(field.Min)" max="@(field.Max)" step="@(field.Step > 0 ? field.Step : 1)"
                                           @oninput='e => UpdateConfig(field.Name, e.Value)'
                                           class="w-full bg-gray-700 text-gray-200 text-sm px-2 py-1 rounded focus:outline-none focus:ring-1 focus:ring-blue-500" />
                                    break;

                                case "boolean":
                                    <label class="inline-flex items-center gap-2 cursor-pointer">
                                        <div class="relative">
                                            <input type="checkbox"
                                                   checked="@IsBoolChecked(field)"
                                                   @onchange='e => UpdateConfig(field.Name, (bool)(e.Value ?? false) ? "true" : "false")'
                                                   class="sr-only peer" />
                                            <div class="w-9 h-5 bg-gray-600 rounded-full peer peer-checked:bg-blue-500 transition-colors"></div>
                                            <div class="absolute left-0.5 top-0.5 w-4 h-4 bg-white rounded-full transition-transform peer-checked:translate-x-4"></div>
                                        </div>
                                        <span class="text-xs text-gray-300">@(IsBoolChecked(field) ? "Enabled" : "Disabled")</span>
                                    </label>
                                    break;

                                case "password":
                                    <input type="password"
                                           value="@GetConfigValue(field)"
                                           placeholder="@(field.Default ?? "")"
                                           @oninput='e => UpdateConfig(field.Name, e.Value)'
                                           class="w-full bg-gray-700 text-gray-200 text-sm px-2 py-1 rounded focus:outline-none focus:ring-1 focus:ring-blue-500" />
                                    break;

                                default:
                                    <input type="text"
                                           value="@GetConfigValue(field)"
                                           placeholder="@(field.Default ?? "")"
                                           @oninput='e => UpdateConfig(field.Name, e.Value)'
                                           class="w-full bg-gray-700 text-gray-200 text-sm px-2 py-1 rounded focus:outline-none focus:ring-1 focus:ring-blue-500" />
                                    break;
                            }

                             @if (field.HelpText is not null)
                             {
                                 <p class="text-[10px] text-gray-500 mt-0.5">@field.HelpText</p>
                             }

                             @if (IsWorkflowReferenceField(field))
                             {
                                 <div class="mt-2 rounded border border-violet-500/20 bg-violet-500/10 p-2 text-[10px]" data-testid="properties-workflow-reference-@field.Name">
                                     <div class="mb-1 flex items-center justify-between gap-2">
                                         <span class="font-semibold uppercase tracking-wider text-violet-200">Saved workflows</span>
                                         @if (_availableWorkflowReferences.Count > 0)
                                         {
                                             <span class="text-violet-200/70">@_availableWorkflowReferences.Count available</span>
                                         }
                                     </div>

                                     @if (_loadingWorkflowReferences)
                                     {
                                         <p class="text-violet-100/70">Loading reusable workflow references...</p>
                                     }
                                     else if (_workflowReferenceError is not null)
                                     {
                                         <p class="text-red-200">@_workflowReferenceError</p>
                                     }
                                     else if (_availableWorkflowReferences.Count == 0)
                                     {
                                         <p class="text-violet-100/70">Save another workflow to reuse it here as a child flow.</p>
                                     }
                                     else if (GetWorkflowReferenceSuggestions(field).Count == 0)
                                     {
                                         <p class="text-violet-100/70">No saved workflows match the current name yet.</p>
                                     }
                                     else
                                     {
                                         <div class="flex flex-wrap gap-1.5">
                                             @foreach (var workflow in GetWorkflowReferenceSuggestions(field))
                                             {
                                                 <button type="button"
                                                         @onclick="() => SelectWorkflowReferenceAsync(field.Name, workflow.Name)"
                                                         data-testid="properties-workflow-reference-option-@field.Name"
                                                         class="rounded border border-violet-400/30 bg-violet-500/10 px-2 py-1 text-left text-violet-100 hover:bg-violet-500/20">
                                                     <span class="font-medium">@workflow.Name</span>
                                                     <span class="ml-1 text-violet-100/60">@GetWorkflowReferenceOptionLabel(workflow)</span>
                                                 </button>
                                             }
                                         </div>
                                     }
                                 </div>
                             }

                             @if (IsWorkflowReferenceField(field) && GetSelectedWorkflowReference(field) is { } selectedWorkflowReference)
                             {
                                 <div class="mt-2 rounded border border-emerald-500/20 bg-emerald-500/10 p-2 text-[10px] text-emerald-100" data-testid="properties-workflow-reference-match-@field.Name">
                                     <p class="font-semibold uppercase tracking-wider text-emerald-200 mb-1">Selected child workflow</p>
                                     <p>@selectedWorkflowReference.Name · @GetWorkflowReferenceOptionLabel(selectedWorkflowReference)</p>
                                     @if (!string.IsNullOrWhiteSpace(selectedWorkflowReference.Description))
                                     {
                                         <p class="mt-1 text-emerald-100/80">@selectedWorkflowReference.Description</p>
                                     }
                                 </div>
                             }

                             @if (IsWorkflowReferenceField(field) && GetWorkflowReferenceWarning(field) is string workflowReferenceWarning)
                             {
                                 <div class="mt-2 rounded border border-amber-500/30 bg-amber-500/10 p-2 text-[10px] text-amber-100" data-testid="properties-workflow-reference-warnings-@field.Name">
                                     <p class="font-semibold uppercase tracking-wider text-amber-200 mb-1">Reference warning</p>
                                     <p>@workflowReferenceWarning</p>
                                 </div>
                             }

                             @if (field.SupportsVariables)
                             {
                                 <div class="mt-2 rounded border border-gray-700 bg-gray-900/40 p-2 text-[10px]" data-testid="properties-variables-@field.Name">
                                     <div class="flex items-center justify-between gap-2 mb-1">
                                        <span class="uppercase tracking-wider text-gray-500 font-semibold">Variables</span>
                                        <span class="text-gray-500">@GetVariableSyntax(field)</span>
                                    </div>

                                    @if (AvailableVariables.Count == 0)
                                    {
                                        <p class="text-gray-500">Connect an upstream step to surface reusable outputs here.</p>
                                    }
                                    else
                                    {
                                        @foreach (var group in GetVariableReferenceGroups())
                                        {
                                            <div class="mb-2 last:mb-0">
                                                <p class="text-gray-400 font-semibold mb-1">@group.Key</p>
                                                <div class="flex flex-wrap gap-1">
                                                    @foreach (var variable in group)
                                                    {
                                                        <button type="button"
                                                                @onclick="() => InsertVariableAsync(field.Name, variable.Token)"
                                                                class="rounded border border-cyan-500/20 bg-cyan-500/10 px-1.5 py-0.5 text-cyan-200 hover:bg-cyan-500/20">
                                                            @variable.Token
                                                        </button>
                                                    }
                                                </div>
                                                @if (group.Any(variable => !string.IsNullOrWhiteSpace(variable.Description)))
                                                {
                                                    <div class="mt-1 space-y-0.5 text-gray-500">
                                                        @foreach (var variable in group.Where(variable => !string.IsNullOrWhiteSpace(variable.Description)))
                                                        {
                                                            <p><span class="text-cyan-200">@variable.Token</span> - @variable.Description</p>
                                                        }
                                                    </div>
                                                }
                                            </div>
                                        }
                                    }
                                </div>
                            }

                            @if (field.SupportsVariables && GetUnresolvedVariableTokens(field).Count > 0)
                            {
                                <div class="mt-2 rounded border border-red-500/30 bg-red-500/10 p-2 text-[10px] text-red-200" data-testid="properties-variable-warnings-@field.Name">
                                    <p class="font-semibold uppercase tracking-wider text-red-300 mb-1">Unresolved variables</p>
                                    @foreach (var token in GetUnresolvedVariableTokens(field))
                                    {
                                        <p>@token</p>
                                    }
                                </div>
                            }
                        </div>
                    }
                </div>
            }
            else if (stepDef is not null && stepDef.Properties.Count > 0)
            {
                <div class="border-t border-gray-700 pt-2">
                    <label class="block text-xs text-gray-400 mb-1.5 uppercase tracking-wider font-semibold">Configuration</label>
                    @foreach (var prop in stepDef.Properties)
                    {
                        <div class="mb-2">
                            <label class="block text-xs text-gray-400 mb-1">
                                @prop.Label
                                @if (prop.Required) { <span class="text-red-400">*</span> }
                            </label>
                            @if (prop.Type == "select" && prop.Options is not null)
                            {
                                <select value="@(NodeConfig.GetValueOrDefault(prop.Name)?.ToString() ?? prop.DefaultValue ?? string.Empty)"
                                        @onchange='e => UpdateConfig(prop.Name, e.Value)'
                                        class="w-full bg-gray-700 text-gray-200 text-sm px-2 py-1 rounded focus:outline-none focus:ring-1 focus:ring-blue-500">
                                    @foreach (var opt in prop.Options)
                                    {
                                        <option value="@opt">@opt</option>
                                    }
                                </select>
                            }
                            else if (prop.Type == "bool")
                            {
                                <input type="checkbox"
                                       checked="@(NodeConfig.GetValueOrDefault(prop.Name)?.ToString() == "true")"
                                       @onchange='e => UpdateConfig(prop.Name, e.Value)'
                                       class="rounded bg-gray-700" />
                            }
                            else
                            {
                                <input type="@(prop.Type == "number" ? "number" : "text")"
                                       value="@(NodeConfig.GetValueOrDefault(prop.Name)?.ToString() ?? prop.DefaultValue ?? string.Empty)"
                                       @oninput='e => UpdateConfig(prop.Name, e.Value)'
                                       class="w-full bg-gray-700 text-gray-200 text-sm px-2 py-1 rounded focus:outline-none focus:ring-1 focus:ring-blue-500" />
                            }
                        </div>
                    }
                </div>
            }
        </div>
    }
</div>

@code {
    private static readonly System.Text.RegularExpressions.Regex DirectTokenPattern = new(@"\{\{\s*([^{}]+?)\s*\}\}", System.Text.RegularExpressions.RegexOptions.Compiled);
    private static readonly System.Text.RegularExpressions.Regex LegacyTokenPattern = new(@"\{([A-Za-z0-9_]+)\}", System.Text.RegularExpressions.RegexOptions.Compiled);

    [Parameter] public string? SelectedNodeId { get; set; }
    [Parameter] public string? SelectedNodeType { get; set; }
    [Parameter] public string? WorkflowName { get; set; }
    [Parameter] public Dictionary<string, object?> NodeConfig { get; set; } = new();
    [Parameter] public EventCallback<Dictionary<string, object?>> OnConfigChanged { get; set; }
    [Parameter] public NodeConnections? Connections { get; set; }
    [Parameter] public EventCallback<string> OnConnectionClicked { get; set; }
    [Parameter] public IReadOnlyList<VariableReferenceInfo> AvailableVariables { get; set; } = [];

    private List<StepDefinition> _localSteps = StepCatalog.GetAll();
    private bool _loadingSchema;
    private bool _loadingProviderModels;
    private bool _loadingWorkflowReferences;
    private List<SchemaField> _schemaFields = [];
    private static readonly TimeSpan ProviderModelRefreshInterval = TimeSpan.FromSeconds(5);
    private string? _lastLoadedType;
    private string? _lastLoadedNodeId;
    private string? _lastLoadedModelProvider;
    private string? _ollamaRefreshNodeId;
    private CancellationTokenSource? _ollamaRefreshCancellation;
    private string? _stepTypeDescription;
    private string? _workflowReferenceError;
    private List<WorkflowReferenceInfo> _availableWorkflowReferences = [];
    private readonly Dictionary<string, IReadOnlyList<string>> _providerModelOptions = new(StringComparer.OrdinalIgnoreCase);

    public sealed class NodeConnections
    {
        public List<ConnectionInfo> Inputs { get; set; } = [];
        public List<ConnectionInfo> Outputs { get; set; } = [];
    }

    public sealed class ConnectionInfo
    {
        public string Id { get; set; } = "";
        public string Label { get; set; } = "";
        public string? EdgeLabel { get; set; }
    }

    public sealed class VariableReferenceInfo
    {
        public string Token { get; set; } = "";
        public string GroupLabel { get; set; } = "";
        public string? Description { get; set; }
    }

    private sealed class WorkflowReferenceInfo
    {
        public string Name { get; set; } = "";
        public string? Description { get; set; }
        public int StepCount { get; set; }
    }

    private sealed class SchemaField
    {
        public string Name { get; set; } = "";
        public string Label { get; set; } = "";
        public string UiType { get; set; } = "text";
        public string? HelpText { get; set; }
        public bool Required { get; set; }
        public int Rows { get; set; }
        public double Min { get; set; }
        public double Max { get; set; } = 100;
        public double Step { get; set; }
        public string? Default { get; set; }
        public string? DependsOn { get; set; }
        public List<string>? Options { get; set; }
        public Dictionary<string, List<string>>? OptionGroups { get; set; }
        public bool SupportsVariables { get; set; }
        public string? VariableSyntax { get; set; }
    }

    private static bool IsContainerType(string? type) => type?.ToLowerInvariant() is
        "parallel" or "conditional" or "trycatch" or "saga" or "foreach" or "while" or "dowhile" or "retry";

    private string GetConfigValue(SchemaField field)
    {
        return NodeConfig.GetValueOrDefault(field.Name)?.ToString() ?? string.Empty;
    }

    private bool IsBoolChecked(SchemaField field)
    {
        var val = NodeConfig.GetValueOrDefault(field.Name)?.ToString()?.ToLowerInvariant();
        return val == "true" || (val is null && field.Default == "true");
    }

    protected override async Task OnParametersSetAsync()
    {
        if (SelectedNodeType is not null && (SelectedNodeType != _lastLoadedType || SelectedNodeId != _lastLoadedNodeId))
        {
            _lastLoadedType = SelectedNodeType;
            _lastLoadedNodeId = SelectedNodeId;
            await LoadSchema(SelectedNodeType);
        }
        else if (SelectedNodeType is null)
        {
            _lastLoadedType = null;
            _lastLoadedNodeId = null;
            _lastLoadedModelProvider = null;
            _schemaFields = [];
            _stepTypeDescription = null;
            _providerModelOptions.Clear();
            _availableWorkflowReferences = [];
            _workflowReferenceError = null;
            StopOllamaRefreshLoop();
        }
        else if (RequiresDynamicProviderModels())
        {
            var currentProvider = GetCurrentModelProvider();
            if (!string.Equals(currentProvider, _lastLoadedModelProvider, StringComparison.OrdinalIgnoreCase))
                await LoadProviderModelsAsync(currentProvider);

            SyncOllamaRefreshLoop(currentProvider);
        }
        else
        {
            StopOllamaRefreshLoop();
        }
    }

    private async Task LoadSchema(string type)
    {
        _loadingSchema = true;
        _schemaFields = [];
        _stepTypeDescription = null;
        try
        {
            var info = await Api.GetStepTypeAsync(type);
            if (info is not null)
            {
                _stepTypeDescription = info.Description;
                if (info.ConfigSchema is not null)
                {
                    var schema = info.ConfigSchema.Value;
                    // Collect top-level required array
                    var topRequired = new HashSet<string>();
                    if (schema.TryGetProperty("required", out var reqArray) && reqArray.ValueKind == System.Text.Json.JsonValueKind.Array)
                    {
                        foreach (var r in reqArray.EnumerateArray())
                            topRequired.Add(r.GetString() ?? "");
                    }

                    if (schema.TryGetProperty("properties", out var props))
                    {
                        foreach (var prop in props.EnumerateObject())
                        {
                            var field = new SchemaField { Name = prop.Name };

                            // Label
                            field.Label = prop.Value.TryGetProperty("label", out var lbl)
                                ? lbl.GetString() ?? prop.Name
                                : prop.Name[..1].ToUpper() + prop.Name[1..];

                            // uiType
                            if (prop.Value.TryGetProperty("uiType", out var ui))
                                field.UiType = ui.GetString() ?? "text";
                            else if (prop.Value.TryGetProperty("type", out var t))
                            {
                                var schemaType = t.GetString();
                                field.UiType = schemaType == "boolean" ? "boolean" : schemaType == "number" ? "number" : "text";
                            }

                            // Required (field-level or top-level)
                            if (prop.Value.TryGetProperty("required", out var req) && req.ValueKind == System.Text.Json.JsonValueKind.True)
                                field.Required = true;
                            else if (topRequired.Contains(prop.Name))
                                field.Required = true;

                            // HelpText
                            if (prop.Value.TryGetProperty("helpText", out var ht))
                                field.HelpText = ht.GetString();

                            // Rows
                            if (prop.Value.TryGetProperty("rows", out var rows))
                                field.Rows = rows.GetInt32();

                            // Min/Max/Step
                            if (prop.Value.TryGetProperty("min", out var mn))
                                field.Min = mn.GetDouble();
                            if (prop.Value.TryGetProperty("max", out var mx))
                                field.Max = mx.GetDouble();
                            if (prop.Value.TryGetProperty("step", out var st))
                                field.Step = st.GetDouble();

                            // Default
                            if (prop.Value.TryGetProperty("default", out var def))
                                field.Default = def.ToString();

                            // DependsOn
                            if (prop.Value.TryGetProperty("dependsOn", out var dep))
                                field.DependsOn = dep.GetString();

                            if (prop.Value.TryGetProperty("supportsVariables", out var supportsVariables)
                                && supportsVariables.ValueKind is System.Text.Json.JsonValueKind.True or System.Text.Json.JsonValueKind.False)
                            {
                                field.SupportsVariables = supportsVariables.GetBoolean();
                            }

                            if (prop.Value.TryGetProperty("variableSyntax", out var variableSyntax))
                                field.VariableSyntax = variableSyntax.GetString();

                            // Options (from enum or options array)
                            if (prop.Value.TryGetProperty("options", out var opts) && opts.ValueKind == System.Text.Json.JsonValueKind.Array)
                            {
                                field.Options = [];
                                foreach (var o in opts.EnumerateArray())
                                    field.Options.Add(o.GetString() ?? "");
                            }
                            else if (prop.Value.TryGetProperty("enum", out var en) && en.ValueKind == System.Text.Json.JsonValueKind.Array)
                            {
                                field.Options = [];
                                field.UiType = field.UiType == "text" ? "select" : field.UiType;
                                foreach (var o in en.EnumerateArray())
                                    field.Options.Add(o.GetString() ?? "");
                            }

                            if (prop.Value.TryGetProperty("optionGroups", out var groups) && groups.ValueKind == System.Text.Json.JsonValueKind.Object)
                            {
                                field.OptionGroups = new Dictionary<string, List<string>>(StringComparer.OrdinalIgnoreCase);
                                foreach (var group in groups.EnumerateObject())
                                {
                                    if (group.Value.ValueKind != System.Text.Json.JsonValueKind.Array)
                                        continue;

                                    var options = new List<string>();
                                    foreach (var item in group.Value.EnumerateArray())
                                        options.Add(item.GetString() ?? "");

                                    field.OptionGroups[group.Name] = options;
                                }
                            }

                            _schemaFields.Add(field);
                        }
                    }
                }
            }
        }
        catch
        {
            _schemaFields = BuildLocalSchemaFields(type);
        }
        finally
        {
            if (_schemaFields.Count == 0)
                _schemaFields = BuildLocalSchemaFields(type);

            _loadingSchema = false;
        }

        await LoadProviderModelsAsync(GetCurrentModelProvider());

        if (_schemaFields.Any(IsWorkflowReferenceField))
        {
            await LoadWorkflowReferencesAsync();
        }
        else
        {
            _availableWorkflowReferences = [];
            _workflowReferenceError = null;
            _loadingWorkflowReferences = false;
        }

        SyncOllamaRefreshLoop();
    }

    private List<SchemaField> BuildLocalSchemaFields(string type)
    {
        var stepDef = _localSteps.FirstOrDefault(step => string.Equals(step.Type, type, StringComparison.OrdinalIgnoreCase));
        if (stepDef is null)
            return [];

        return stepDef.Properties.Select(prop => new SchemaField
        {
            Name = prop.Name,
            Label = prop.Label,
            UiType = prop.UiType ?? (prop.Type == "bool" ? "boolean" : prop.Type == "number" ? "number" : prop.Type == "select" ? "select" : "text"),
            Required = prop.Required,
            Default = prop.DefaultValue,
            DependsOn = prop.DependsOn,
            Options = prop.Options is null ? null : [.. prop.Options],
            SupportsVariables = prop.SupportsVariables,
            VariableSyntax = prop.VariableSyntax,
            OptionGroups = prop.OptionGroups?.ToDictionary(
                pair => pair.Key,
                pair => pair.Value.ToList(),
                StringComparer.OrdinalIgnoreCase)
        }).ToList();
    }

    private IReadOnlyList<string> GetAvailableOptions(SchemaField field)
    {
        if (IsDynamicModelField(field))
        {
            var currentValue = NodeConfig.GetValueOrDefault(field.Name)?.ToString();
            var options = GetDynamicModelSuggestions(field).ToList();

            if (!string.IsNullOrWhiteSpace(currentValue) &&
                !options.Any(option => string.Equals(option, currentValue, StringComparison.OrdinalIgnoreCase)))
            {
                options.Insert(0, currentValue);
            }

            return options;
        }

        if (field.DependsOn is not null)
        {
            var dependencyValue = NodeConfig.GetValueOrDefault(field.DependsOn)?.ToString();
            if (!string.IsNullOrWhiteSpace(dependencyValue) &&
                field.OptionGroups is not null &&
                field.OptionGroups.TryGetValue(dependencyValue, out var groupedOptions))
            {
                return groupedOptions;
            }
        }

        return field.Options ?? [];
    }

    private static string FormatOptionLabel(string option)
        => option.ToLowerInvariant() switch
        {
            "ollama" => "Ollama",
            "openai" => "OpenAI",
            "anthropic" => "Anthropic",
            "huggingface" => "Hugging Face",
            _ => option
        };

    private string GetModelPlaceholder(SchemaField field)
    {
        if (field.DependsOn is not null && string.IsNullOrWhiteSpace(NodeConfig.GetValueOrDefault(field.DependsOn)?.ToString()))
            return "— Select provider first —";

        if (IsDynamicModelField(field) && _loadingProviderModels)
            return "Loading models...";

        return GetAvailableOptions(field).Count == 0
            ? IsDynamicModelField(field)
                ? "Enter a model name or verify the provider connection"
                : "— No models available —"
            : "— Select model —";
    }

    private bool UsesManualModelEntry(SchemaField field)
        => IsDynamicModelField(field)
           && !string.IsNullOrWhiteSpace(GetCurrentProviderValue(field))
           && GetDynamicModelSuggestions(field).Count == 0;

    private async Task OnProviderChangedAsync(SchemaField field, string? provider)
    {
        var newConfig = new Dictionary<string, object?>(NodeConfig)
        {
            [field.Name] = provider ?? string.Empty
        };

        await LoadProviderModelsAsync(provider);

        foreach (var dependentField in _schemaFields.Where(schemaField =>
                     schemaField.DependsOn is not null &&
                     string.Equals(schemaField.DependsOn, field.Name, StringComparison.OrdinalIgnoreCase)))
        {
            if (IsDynamicModelField(dependentField))
            {
                newConfig.Remove(dependentField.Name);
                continue;
            }

            var selectedValue = newConfig.GetValueOrDefault(dependentField.Name)?.ToString();
            if (string.IsNullOrWhiteSpace(selectedValue))
                continue;

            var validOptions = GetAvailableOptionsForConfig(dependentField, newConfig);
            if (!validOptions.Any(option => string.Equals(option, selectedValue, StringComparison.OrdinalIgnoreCase)))
                newConfig.Remove(dependentField.Name);
        }

        await OnConfigChanged.InvokeAsync(newConfig);
    }

    private bool RequiresDynamicProviderModels()
        => _schemaFields.Any(IsDynamicModelField);

    private static bool IsDynamicModelField(SchemaField field)
        => string.Equals(field.UiType, "modelSelect", StringComparison.OrdinalIgnoreCase)
           && string.Equals(field.DependsOn, "provider", StringComparison.OrdinalIgnoreCase);

    private string? GetCurrentProviderValue(SchemaField field)
        => field.DependsOn is null
            ? null
            : NodeConfig.GetValueOrDefault(field.DependsOn)?.ToString();

    private IReadOnlyList<string> GetDynamicModelSuggestions(SchemaField field)
    {
        var provider = GetCurrentProviderValue(field);
        if (string.IsNullOrWhiteSpace(provider))
            return [];

        if (_providerModelOptions.TryGetValue(provider, out var dynamicModels))
            return dynamicModels;

        if (!string.Equals(provider, "ollama", StringComparison.OrdinalIgnoreCase) &&
            field.OptionGroups is not null &&
            field.OptionGroups.TryGetValue(provider, out var fallbackOptions))
        {
            return fallbackOptions;
        }

        return [];
    }

    private string? GetCurrentModelProvider()
    {
        var modelField = _schemaFields.FirstOrDefault(IsDynamicModelField);
        return modelField is null
            ? null
            : NodeConfig.GetValueOrDefault(modelField.DependsOn!)?.ToString();
    }

    private async Task LoadProviderModelsAsync(string? provider)
    {
        _lastLoadedModelProvider = null;

        if (string.IsNullOrWhiteSpace(provider))
            return;

        _loadingProviderModels = true;
        try
        {
            var models = await Api.GetProviderModelsAsync(provider);
            _providerModelOptions[provider] = models;
            _lastLoadedModelProvider = provider;
        }
        catch (System.Net.Http.HttpRequestException)
        {
            _lastLoadedModelProvider = provider;
        }
        catch (System.Text.Json.JsonException)
        {
            _lastLoadedModelProvider = provider;
        }
        catch (NotSupportedException)
        {
            _lastLoadedModelProvider = provider;
        }
        catch (TaskCanceledException)
        {
            _lastLoadedModelProvider = provider;
        }
        finally
        {
            _loadingProviderModels = false;
        }
    }

    private string GetProviderModelSuggestionListId(SchemaField field)
        => $"provider-model-suggestions-{field.Name}-{SelectedNodeId ?? "node"}";

    private void SyncOllamaRefreshLoop(string? provider = null)
    {
        var currentProvider = provider ?? GetCurrentModelProvider();
        if (!string.Equals(currentProvider, "ollama", StringComparison.OrdinalIgnoreCase) || string.IsNullOrWhiteSpace(SelectedNodeId))
        {
            StopOllamaRefreshLoop();
            return;
        }

        if (_ollamaRefreshCancellation is not null &&
            string.Equals(_ollamaRefreshNodeId, SelectedNodeId, StringComparison.Ordinal))
        {
            return;
        }

        StopOllamaRefreshLoop();

        _ollamaRefreshNodeId = SelectedNodeId;
        _ollamaRefreshCancellation = new CancellationTokenSource();
        var cancellationToken = _ollamaRefreshCancellation.Token;

        _ = Task.Run(async () =>
        {
            try
            {
                using var timer = new PeriodicTimer(ProviderModelRefreshInterval);
                while (await timer.WaitForNextTickAsync(cancellationToken))
                {
                    await InvokeAsync(async () =>
                    {
                        await LoadProviderModelsAsync("ollama");
                        StateHasChanged();
                    });
                }
            }
            catch (OperationCanceledException)
            {
            }
        }, cancellationToken);
    }

    private void StopOllamaRefreshLoop()
    {
        _ollamaRefreshCancellation?.Cancel();
        _ollamaRefreshCancellation?.Dispose();
        _ollamaRefreshCancellation = null;
        _ollamaRefreshNodeId = null;
    }

    private static IReadOnlyList<string> GetAvailableOptionsForConfig(SchemaField field, Dictionary<string, object?> config)
    {
        if (field.DependsOn is not null)
        {
            var dependencyValue = config.GetValueOrDefault(field.DependsOn)?.ToString();
            if (!string.IsNullOrWhiteSpace(dependencyValue) &&
                field.OptionGroups is not null &&
                field.OptionGroups.TryGetValue(dependencyValue, out var groupedOptions))
            {
                return groupedOptions;
            }
        }

        return field.Options ?? [];
    }

    private async Task UpdateConfig(string key, object? value)
    {
        var newConfig = new Dictionary<string, object?>(NodeConfig) { [key] = value };
        await OnConfigChanged.InvokeAsync(newConfig);
    }

    public void Dispose()
        => StopOllamaRefreshLoop();

    private static bool IsWorkflowReferenceField(SchemaField field)
        => string.Equals(field.UiType, "workflowSelect", StringComparison.OrdinalIgnoreCase);

    private async Task LoadWorkflowReferencesAsync()
    {
        _loadingWorkflowReferences = true;
        _workflowReferenceError = null;

        try
        {
            var workflows = await Api.GetWorkflowsAsync();
            _availableWorkflowReferences = workflows
                .Where(workflow => !string.IsNullOrWhiteSpace(workflow.Name))
                .GroupBy(workflow => workflow.Name.Trim(), StringComparer.OrdinalIgnoreCase)
                .Select(group => group.OrderByDescending(workflow => workflow.LastModified).First())
                .Select(workflow => new WorkflowReferenceInfo
                {
                    Name = workflow.Name.Trim(),
                    Description = workflow.Description,
                    StepCount = workflow.StepCount
                })
                .OrderBy(workflow => workflow.Name, StringComparer.OrdinalIgnoreCase)
                .ToList();
        }
        catch (Exception ex)
        {
            _availableWorkflowReferences = [];
            _workflowReferenceError = $"Failed to load workflows: {ex.Message}";
        }
        finally
        {
            _loadingWorkflowReferences = false;
        }
    }

    private string GetWorkflowReferenceListId(SchemaField field)
        => $"workflow-reference-{field.Name}-{SelectedNodeId ?? "node"}";

    private IReadOnlyList<WorkflowReferenceInfo> GetWorkflowReferenceSuggestions(SchemaField field)
    {
        var currentValue = NodeConfig.GetValueOrDefault(field.Name)?.ToString()?.Trim();
        IEnumerable<WorkflowReferenceInfo> query = _availableWorkflowReferences
            .Where(workflow => !string.Equals(workflow.Name, WorkflowName?.Trim(), StringComparison.OrdinalIgnoreCase));

        if (!string.IsNullOrWhiteSpace(currentValue))
        {
            query = query.Where(workflow =>
                workflow.Name.Contains(currentValue, StringComparison.OrdinalIgnoreCase) ||
                (workflow.Description?.Contains(currentValue, StringComparison.OrdinalIgnoreCase) ?? false));
        }

        return query
            .OrderByDescending(workflow => !string.IsNullOrWhiteSpace(currentValue) && workflow.Name.StartsWith(currentValue, StringComparison.OrdinalIgnoreCase))
            .ThenBy(workflow => workflow.Name, StringComparer.OrdinalIgnoreCase)
            .Take(8)
            .ToList();
    }

    private WorkflowReferenceInfo? GetSelectedWorkflowReference(SchemaField field)
    {
        var selectedWorkflowName = NodeConfig.GetValueOrDefault(field.Name)?.ToString()?.Trim();
        if (string.IsNullOrWhiteSpace(selectedWorkflowName))
            return null;

        return _availableWorkflowReferences.FirstOrDefault(workflow =>
            !string.Equals(workflow.Name, WorkflowName?.Trim(), StringComparison.OrdinalIgnoreCase) &&
            string.Equals(workflow.Name, selectedWorkflowName, StringComparison.OrdinalIgnoreCase));
    }

    private string? GetWorkflowReferenceWarning(SchemaField field)
        => GetWorkflowReferenceWarning(
            NodeConfig.GetValueOrDefault(field.Name)?.ToString(),
            WorkflowName,
            _availableWorkflowReferences.Select(workflow => workflow.Name).ToList(),
            !_loadingWorkflowReferences && _workflowReferenceError is null);

    private static string? GetWorkflowReferenceWarning(
        string? selectedWorkflowName,
        string? currentWorkflowName,
        IReadOnlyList<string> availableWorkflowNames,
        bool hasReferenceCatalog)
    {
        if (string.IsNullOrWhiteSpace(selectedWorkflowName))
            return null;

        var trimmedSelectedWorkflowName = selectedWorkflowName.Trim();
        if (!string.IsNullOrWhiteSpace(currentWorkflowName)
            && string.Equals(trimmedSelectedWorkflowName, currentWorkflowName.Trim(), StringComparison.OrdinalIgnoreCase))
        {
            return "Sub-workflow cannot reference the current workflow.";
        }

        if (!hasReferenceCatalog || availableWorkflowNames.Count == 0)
            return null;

        return availableWorkflowNames.Any(workflowName => string.Equals(workflowName, trimmedSelectedWorkflowName, StringComparison.OrdinalIgnoreCase))
            ? null
            : "No saved workflow matches this name yet. You can keep typing if the child workflow will be created later.";
    }

    private static string GetWorkflowReferenceOptionLabel(WorkflowReferenceInfo workflow)
        => workflow.StepCount == 1 ? "1 step" : $"{workflow.StepCount} steps";

    private Task SelectWorkflowReferenceAsync(string key, string workflowName)
        => UpdateConfig(key, workflowName);

    private IEnumerable<IGrouping<string, VariableReferenceInfo>> GetVariableReferenceGroups()
        => AvailableVariables
            .Where(variable => !string.IsNullOrWhiteSpace(variable.Token))
            .GroupBy(variable => string.IsNullOrWhiteSpace(variable.GroupLabel) ? "Available outputs" : variable.GroupLabel);

    private string GetVariableSyntax(SchemaField field)
        => field.VariableSyntax ?? "Use {{Step Name.Output}} or {InputName}";

    private async Task InsertVariableAsync(string key, string token)
    {
        var currentValue = NodeConfig.GetValueOrDefault(key)?.ToString() ?? string.Empty;
        var separator = currentValue.Length == 0 || char.IsWhiteSpace(currentValue[^1]) || currentValue[^1] is '\n' or '\r'
            ? string.Empty
            : " ";

        await UpdateConfig(key, currentValue + separator + token);
    }

    private IReadOnlyList<string> GetUnresolvedVariableTokens(SchemaField field)
    {
        var currentValue = NodeConfig.GetValueOrDefault(field.Name)?.ToString();
        return GetUnresolvedVariableTokens(currentValue, AvailableVariables);
    }

    private static IReadOnlyList<string> GetUnresolvedVariableTokens(string? value, IReadOnlyList<VariableReferenceInfo> availableVariables)
    {
        if (string.IsNullOrWhiteSpace(value))
            return [];

        var availableTokenSet = new HashSet<string>(
            availableVariables
                .Where(variable => !string.IsNullOrWhiteSpace(variable.Token))
                .Select(variable => NormalizeVariableToken(variable.Token)),
            StringComparer.Ordinal);

        var unresolved = new List<string>();
        foreach (var token in GetReferencedVariableTokens(value))
        {
            if (!availableTokenSet.Contains(NormalizeVariableToken(token)))
                unresolved.Add(token);
        }

        return unresolved;
    }

    private static IReadOnlyList<string> GetReferencedVariableTokens(string value)
    {
        var tokens = new List<string>();

        foreach (System.Text.RegularExpressions.Match match in DirectTokenPattern.Matches(value))
            tokens.Add(NormalizeVariableToken(match.Value));

        foreach (System.Text.RegularExpressions.Match match in LegacyTokenPattern.Matches(value))
            tokens.Add(NormalizeVariableToken(match.Value));

        return tokens;
    }

    private static string NormalizeVariableToken(string token)
    {
        if (token.StartsWith("{{", StringComparison.Ordinal) && token.EndsWith("}}", StringComparison.Ordinal))
            return "{{" + token[2..^2].Trim() + "}}";

        return token.Trim();
    }
}
